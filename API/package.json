{
  "name": "@uoa/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "lint": "node ../node_modules/eslint/bin/eslint.js \"**/*.{ts,tsx,js,jsx,mjs,cjs}\" --no-error-on-unmatched-pattern",
    "lint:openapi": "redocly lint openapi.yaml",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.994.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.1.0",
    "@google-cloud/storage": "^7.21.0",
    "@prisma/client": "^6.3.1",
    "@sendgrid/mail": "^8.1.6",
    "@unlikeotherai/qr-art": "^0.1.0",
    "argon2": "^0.44.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "fastify-raw-body": "5.0.0",
    "jose": "^5.9.6",
    "nodemailer": "^9.0.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "stripe": "22.3.2",
    "undici": "^6.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.12",
    "@types/node": "^22.13.1",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.6",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
