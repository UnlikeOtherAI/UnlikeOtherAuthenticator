  updatedAt DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

// Brief 8.4 / Phase 10: AI translation fallback results must be cached permanently after generation.
model AiTranslation {
  language   String   @id
  // Hash of the source translation file used to generate this row (lets us regenerate if the source changes).
  sourceHash String   @map("source_hash")
  data       Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([sourceHash])
  @@map("ai_translations")
}

// HUGO-539: Admin API keys — terminal/CI control of feature flags & kill switches.
// Global/superuser-scoped opaque bearer key. The secret is never persisted, only the
// HMAC-SHA256 digest (peppered with SHARED_SECRET). Admin-only table (deny-all RLS for uoa_app).
model AdminApiKey {
  id              String    @id @default(cuid())
  name            String    @db.VarChar(120)
  keyPrefix       String    @map("key_prefix") @db.VarChar(24)
  secretDigest    String    @unique @map("secret_digest")
  lastUsedAt      DateTime? @map("last_used_at")
  expiresAt       DateTime? @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  createdByUserId String?   @map("created_by_user_id")
  createdByEmail  String?   @map("created_by_email") @db.VarChar(200)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("admin_api_keys")
}

// Canonical commercial control plane. Tariffs live in UOA; products and Ledger consume
// signed content-free snapshots and keep raw provider usage separate from price multipliers.
model BillingService {
  id         String   @id @default(cuid())
  identifier String   @unique @db.VarChar(100)
  name       String   @db.VarChar(120)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tariffs                           BillingTariff[]
  assignments                       BillingTariffAssignment[]
  appKeys                           BillingAppKey[]
  stripeCatalogs                    BillingStripeCatalog[]
  stripeCheckouts                   BillingStripeCheckoutSession[]
  stripeSubscriptions               BillingStripeSubscription[]
  accesses                          BillingServiceAccess[]
  adjustments                       BillingCommercialAdjustment[]
  cancellationIntents               BillingCancellationIntent[]
  creditFundingPolicies             BillingCreditFundingPolicy[]
  creditTopUpOffers                 BillingCreditTopUpOffer[]
  creditAutoTopUpOptions            BillingCreditAutoTopUpOption[]
  creditAccountAutoTopUps           BillingCreditAccount[]                    @relation("CreditAccountAutoTopUpService")
  creditEntries                     BillingCreditEntry[]
  creditPaymentAdjustments          BillingCreditPaymentAdjustment[]
  creditTopUpCheckouts              BillingCreditTopUpCheckout[]
  creditSetupCheckouts              BillingCreditSetupCheckout[]
  creditAutoTopUpAttempts           BillingCreditAutoTopUpAttempt[]
  creditSettlements                 BillingCreditUsageSettlement[]
  creditSettlementAdjustments       BillingCreditUsageSettlementAdjustment[]
  creditUsageAllocations            BillingCreditUsageAllocation[]
  creditConsentRevisions            BillingCreditAutoTopUpConsentRevision[]
  creditAutoTopUpDisables           BillingCreditAutoTopUpDisableEvent[]
  creditPortfolioPerspectives       BillingCreditPortfolioSnapshot[]          @relation("CreditPortfolioPerspectiveService")
  recurringAddonOffers              BillingRecurringAddonOffer[]
  recurringAddonCatalogs            BillingRecurringAddonCatalog[]
  recurringAddonCheckouts           BillingRecurringAddonCheckout[]
  recurringAddonSubscriptions       BillingRecurringAddonSubscription[]
  recurringAddonFeaturePolicies     BillingRecurringAddonFeaturePolicy[]
  recurringAddonCancellationIntents BillingRecurringAddonCancellationIntent[]
  contractServiceTerms              BillingContractServiceTerm[]
  invoiceLines                      BillingInvoiceLine[]
  invoiceMeteringRefs               BillingInvoiceMeteringReference[]
  invoiceCreditSettlementRefs       BillingInvoiceCreditSettlementReference[]
  invoiceAddonLines                 BillingInvoiceAddonLine[]

  @@map("billing_services")
}

model BillingTariff {
  id                 String                @id @default(cuid())
  serviceId          String                @map("service_id")
  key                String                @db.VarChar(80)
  version            Int
  name               String                @db.VarChar(120)
