generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERUSER
  USER
}

enum VerificationTokenType {
  LOGIN_LINK
  VERIFY_EMAIL_SET_PASSWORD
  VERIFY_EMAIL
  PASSWORD_RESET
  TWOFA_RESET
  LOGIN_CODE
}

enum ClientDomainIntegrationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum TwoFaPolicy {
  OFF
  OPTIONAL
  REQUIRED
}

enum BanType {
  EMAIL
  PATTERN
  IP
  USER
}

// Slack-style membership lifecycle (Docs/plans/2026-07-07-slack-style-login-and-membership.md §4.1).
// ACTIVE is the only status existing rows carry; DEACTIVATED/REMOVED are set by admin actions and
// retained as tombstones. Read paths filter to ACTIVE; "invited" is NOT a status (it stays a
// pending TeamInvite row) to avoid placeholder accounts and email-enumeration surface.
enum MembershipStatus {
  ACTIVE
  DEACTIVATED
  REMOVED
}

// Per-team join policy (design §4.6). Gates the existing self-join mechanisms rather than replacing
// them. INVITE_ONLY is the current implicit behaviour, so the column is dormant until later phases
// wire the other policies. Kept in the foundation migration to avoid a follow-up schema change.
enum TeamJoinPolicy {
  INVITE_ONLY
  APPROVED_DOMAIN
  REQUEST_TO_JOIN
  OPEN_TO_ORG
  HIDDEN
}

// Invite approval workflow (design §4.7, Phase 4). NOT_REQUIRED is every invite created by an
// org/team owner/admin (or the pre-Phase-4 backend endpoint) — unchanged behaviour. PENDING/APPROVED/
// DENIED are only produced by a plain member's invite when the org's memberInvites setting is
// "admin_approval".
enum InviteApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  DENIED
}

model User {
  id                       String   @id @default(cuid())
  // Note: email is not globally unique because `user_scope` can be "per_domain".
  // Uniqueness is enforced via `user_key` instead (global: email, per_domain: domain|email).
  email                    String   @db.Citext
  userKey                  String   @unique @map("user_key")
  domain                   String?
  passwordHash             String?  @map("password_hash")
  name                     String?
  twoFaEnabled             Boolean  @default(false) @map("2fa_enabled")
  twoFaSecret              String?  @map("2fa_secret")
  twoFaLastAcceptedCounter Int?     @map("2fa_last_accepted_counter")
  avatarUrl                String?  @map("avatar_url")
  tokenVersion             Int      @default(0) @map("token_version")
  createdAt                DateTime @default(now()) @map("created_at")

  domainRoles            DomainRole[]
  authIdentities         AuthIdentity[]
  tokens                 VerificationToken[]
  authorizationCodes     AuthorizationCode[]
  refreshTokens          RefreshToken[]
  loginLogs              LoginLog[]
  ownedOrgs              Organisation[]            @relation("OrgOwner")
  orgMembers             OrgMember[]
  teamMembers            TeamMember[]
  groupMembers           GroupMember[]
  acceptedTeamInvites    TeamInvite[]              @relation("AcceptedTeamInvites")
  accessRequests         AccessRequest[]
  reviewedAccessRequests AccessRequest[]           @relation("ReviewedAccessRequests")
  featureFlagOverrides   FeatureFlagUserOverride[]

  @@index([email])
  @@index([domain])
  @@map("users")
}

// TODO(VM5/M8/VL11): Add OrgEmailDomainRule.teamId index, the partial unique
// index for nullable team_id, and FACEBOOK/LINKEDIN VerificationMethod values
// once the OrgEmailDomainRule model/table lands.

model DomainRole {
  domain    String
  userId    String   @map("user_id")
  role      UserRole @default(USER)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([domain, userId])
  @@index([userId])
  @@map("domain_roles")
}

// Slack-style auth identities (design §4.2). Records which providers a person has linked, giving
// the token `method` claim a persistence home and turning merge-by-verified-email into an auditable
// record instead of a lost merge. Admin-managed (written via the BYPASSRLS admin client during
// authentication); locked down for uoa_app until an app-role read path needs it.
model AuthIdentity {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  provider        String // "email" | "google" | "github" | "microsoft" | "apple" | "facebook" | "linkedin"
  providerSubject String    @map("provider_subject") // provider user id; for "email" the email itself
  email           String    @db.Citext
  providerTenant  String?   @map("provider_tenant") // e.g. Microsoft Entra `tid` (stored, not enforced)
  verifiedAt      DateTime? @map("verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One identity per provider per user — the upsert target. NOT globally unique on
  // (provider, providerSubject): under user_scope "per_domain" the same email or social account
  // legitimately maps to separate user rows on different domains, so a global unique would reject
  // those and break the backfill. Social-subject lookups use the non-unique index below and filter
  // by the resolved domain/user.
  @@unique([userId, provider])
  @@index([userId])
  @@index([provider, providerSubject])
  @@index([email])
  @@map("auth_identities")
}

model VerificationToken {
  id           String                @id @default(cuid())
  type         VerificationTokenType
  email        String
  userKey      String                @map("user_key")
  domain       String?
  configUrl    String                @map("config_url")
  tokenHash    String                @unique @map("token_hash")
  expiresAt    DateTime              @map("expires_at")
  usedAt       DateTime?             @map("used_at")
  attemptCount Int                   @default(0) @map("attempt_count")
  createdAt    DateTime              @default(now()) @map("created_at")

  userId       String?     @map("user_id")
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamInviteId String?     @map("team_invite_id")
  teamInvite   TeamInvite? @relation(fields: [teamInviteId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userKey])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([userId])
  @@index([teamInviteId])
  @@map("verification_tokens")
}

model AuthorizationCode {
  id                  String    @id @default(cuid())
  codeHash            String    @unique @map("code_hash")
  userId              String    @map("user_id")
  domain              String
  // configUrl is null for the public-client / MCP profile (brief §22.14), which has
  // no client-supplied config URL; those rows carry oauthClientId + resource instead.
  configUrl           String?   @map("config_url")
  redirectUrl         String    @map("redirect_url")
  oauthClientId       String?   @map("oauth_client_id")
  resource            String?
  state               String?
  codeChallenge       String?   @map("code_challenge")
  codeChallengeMethod String?   @map("code_challenge_method")
  rememberMe          Boolean   @default(false) @map("remember_me")
  // Workspace scope captured at select-team time (design §7 step 3-4). Dormant until Phase 3b
  // populates it; consumeAuthorizationCode threads it into the issued session's `active` claim.
  orgId               String?   @map("org_id")
  teamId              String?   @map("team_id")
  expiresAt           DateTime  @map("expires_at")
  usedAt              DateTime? @map("used_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([domain])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("authorization_codes")
}

// Public OAuth clients (brief §22.14). Registered via RFC 7591 dynamic client
// registration for the /oauth/* public-client profile. PUBLIC clients only:
// there is NO secret column (§22.3 preserved) — they authenticate with PKCE.
// The only state stored is the redirect-URI allow-list per client.
model OAuthClient {
  id           String   @id @default(cuid())
  clientId     String   @unique @map("client_id")
  clientName   String?  @map("client_name")
  redirectUris String[] @map("redirect_uris")
  scopes       String[]
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("oauth_clients")
}

model RefreshToken {
  id                String    @id @default(cuid())
  tokenHash         String    @unique @map("token_hash")
  familyId          String    @map("family_id")
  parentTokenId     String?   @unique @map("parent_token_id")
  replacedByTokenId String?   @unique @map("replaced_by_token_id")
  userId            String    @map("user_id")
  domain            String
  clientId          String    @map("client_id")
  configUrl         String    @map("config_url")
  // Workspace scope carried from the authorization code that created this session (design §7 step
  // 3-4). Dormant until Phase 3b populates it; rotation preserves it onto the new row.
  orgId             String?   @map("org_id")
  teamId            String?   @map("team_id")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  lastUsedAt        DateTime? @map("last_used_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId])
  @@index([domain])
  @@index([clientId])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("refresh_tokens")
}

model LoginLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  email      String
  domain     String
  authMethod String   @map("auth_method")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([domain, createdAt])
  @@index([createdAt])
  @@map("login_logs")
}

model HandshakeErrorLog {
  id            String   @id @default(cuid())
  app           String?
  appId         String?  @map("app_id")
  domain        String
  organisation  String?
  endpoint      String
  phase         String
  statusCode    Int      @map("status_code")
  errorCode     String   @map("error_code")
  summary       String
  details       Json
  missingClaims Json     @map("missing_claims")
  ip            String?
  userAgent     String?  @map("user_agent")
  requestId     String   @map("request_id")
  requestJson   Json     @map("request_json")
  responseJson  Json     @map("response_json")
  jwtHeader     Json     @map("jwt_header")
  jwtPayload    Json     @map("jwt_payload")
  redactions    Json
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([domain, createdAt])
  @@index([phase, createdAt])
  @@index([errorCode, createdAt])
  @@index([requestId])
  @@map("handshake_error_logs")
}

model ClientDomain {
  id                  String      @id @default(cuid())
  domain              String      @unique
  label               String      @db.VarChar(120)
  status              String      @default("active") @db.VarChar(20)
  twoFaPolicy         TwoFaPolicy @default(OPTIONAL) @map("two_fa_policy")
  allowedEmailDomains String[]    @default([]) @map("allowed_email_domains")
  allowedEmails       String[]    @default([]) @map("allowed_emails")
  allowedRedirectUrls String[]    @default([]) @map("allowed_redirect_urls")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  secrets     ClientDomainSecret[]
  jwks        ClientDomainJwk[]
  claimTokens IntegrationClaimToken[]
  emailConfig DomainEmailConfig?

  @@index([status])
  @@map("client_domains")
}

model DomainEmailConfig {
  domain               String    @id
  enabled              Boolean   @default(false)
  mailingDomain        String?   @map("mailing_domain")
  fromAddress          String?   @map("from_address")
  fromName             String?   @map("from_name")
  replyToDefault       String?   @map("reply_to_default")
  sesRegion            String    @default("eu-west-1") @map("ses_region")
  sesVerification      String?   @map("ses_verification")
  sesDkim              String?   @map("ses_dkim")
  sesVerificationToken String?   @map("ses_verification_token")
  dkimTokens           String[]  @default([]) @map("dkim_tokens")
  lastCheckedAt        DateTime? @map("last_checked_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  domainRef ClientDomain @relation(fields: [domain], references: [domain], onDelete: Cascade)

  @@map("domain_email_configs")
}

model ClientDomainSecret {
  id            String    @id @default(cuid())
  domainId      String    @map("domain_id")
  secretDigest  String    @map("secret_digest")
  hashPrefix    String    @map("hash_prefix") @db.VarChar(16)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  deactivatedAt DateTime? @map("deactivated_at")

  domain ClientDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId, active])
  @@index([secretDigest])
  @@map("client_domain_secrets")
}

model ClientDomainJwk {
  id             String    @id @default(cuid())
  domainId       String    @map("domain_id")
  kid            String    @unique
  jwk            Json
  fingerprint    String
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  deactivatedAt  DateTime? @map("deactivated_at")
  createdByEmail String?   @map("created_by_email")

  domain ClientDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId, active])
  @@map("client_domain_jwks")
}

model ClientDomainIntegrationRequest {
  id                  String                        @id @default(cuid())
  domain              String
  status              ClientDomainIntegrationStatus @default(PENDING)
  contactEmail        String                        @map("contact_email")
  publicJwk           Json                          @map("public_jwk")
  jwkFingerprint      String                        @map("jwk_fingerprint")
  kid                 String
  jwksUrl             String                        @map("jwks_url")
  configUrl           String?                       @map("config_url")
  configSummary       Json?                         @map("config_summary")
  preValidationResult Json?                         @map("pre_validation_result")
  declineReason       String?                       @map("decline_reason")
  reviewedAt          DateTime?                     @map("reviewed_at")
  reviewedByEmail     String?                       @map("reviewed_by_email")
  clientDomainId      String?                       @map("client_domain_id")
  submittedAt         DateTime                      @default(now()) @map("submitted_at")
  lastSeenAt          DateTime                      @default(now()) @map("last_seen_at")

  claimTokens IntegrationClaimToken[]

  @@index([status, submittedAt])
  @@map("client_domain_integration_requests")
}

model IntegrationClaimToken {
  id              String    @id @default(cuid())
  integrationId   String    @map("integration_id")
  clientDomainId  String?   @map("client_domain_id")
  tokenHash       String    @unique @map("token_hash")
  encryptedSecret Bytes?    @map("encrypted_secret")
  encryptionIv    Bytes?    @map("encryption_iv")
  encryptionTag   Bytes?    @map("encryption_tag")
  expiresAt       DateTime  @map("expires_at")
  usedAt          DateTime? @map("used_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  integration  ClientDomainIntegrationRequest @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  clientDomain ClientDomain?                  @relation(fields: [clientDomainId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([clientDomainId])
  @@map("integration_claim_tokens")
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorEmail   String   @map("actor_email")
  action       String
  targetDomain String?  @map("target_domain")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([targetDomain, createdAt])
  @@map("admin_audit_log")
}

// Org-scoped audit log (design §4.10) — distinct from the platform-admin AdminAuditLog above.
// Written from every membership/invite/policy mutation. Admin-managed (BYPASSRLS admin client,
// deny-all for uoa_app) in this phase; a user-facing read endpoint is deferred to a later phase.
model OrgAuditLog {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  actorUserId String?  @map("actor_user_id") // null = system action (auto-enrolment, later SCIM)
  action      String // e.g. "member.deactivated", "invite.approved", "team.join_policy_changed"
  targetType  String   @map("target_type") // "org_member" | "team_member" | "invite" | "invite_link" | "team"
  targetId    String   @map("target_id")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orgId, createdAt])
  @@index([targetType, targetId])
  @@map("org_audit_log")
}

model Organisation {
  id                  String       @id @default(cuid())
  domain              String
  name                String       @db.VarChar(100)
  slug                String       @db.VarChar(120)
  ownerId             String       @map("owner_id")
  iconUrl             String?      @map("icon_url") // external URL only, no local storage (brief §15); §11.3
  twoFaPolicy         TwoFaPolicy? @map("two_fa_policy")
  allowedEmailDomains String[]     @default([]) @map("allowed_email_domains")
  allowedEmails       String[]     @default([]) @map("allowed_emails")
  // Member-initiated invite policy (design §4.7, Phase 4): "allowed" (default, current behaviour —
  // any active member may invite) | "admin_approval" (member invites are created PENDING and mailed
  // only after an owner/admin approves) | "disabled" (only owner/admin may invite). Validated at the
  // app layer, not the DB, matching the org_features JSON pattern.
  memberInvites       String       @default("allowed") @map("member_invites")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  owner          User             @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members        OrgMember[]
  teams          Team[]
  groups         Group[]
  invites        TeamInvite[]
  inviteLinks    TeamInviteLink[]
  accessRequests AccessRequest[]
  apps           App[]
  bans           Ban[]

  @@unique([domain, slug])
  @@index([domain])
  @@index([ownerId])
  @@map("organisations")
}

model OrgMember {
  id              String           @id @default(cuid())
  orgId           String           @map("org_id")
  userId          String           @map("user_id")
  role            String           @default("member") // validated against org_roles config: "owner" | "admin" | "member"
  status          MembershipStatus @default(ACTIVE) // lifecycle (design §4.1); read paths filter to ACTIVE
  statusChangedAt DateTime?        @map("status_changed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId, status])
  @@map("org_members")
}

model App {
  id                    String   @id @default(cuid())
  orgId                 String   @map("org_id")
  name                  String   @db.VarChar(120)
  identifier            String   @db.VarChar(160)
  platform              String   @db.VarChar(20)
  domains               Json     @default("[]")
  storeUrl              String?  @map("store_url")
  offlinePolicy         String   @default("allow") @map("offline_policy") @db.VarChar(20)
  pollIntervalSeconds   Int      @default(300) @map("poll_interval_seconds")
  featureFlagsEnabled   Boolean  @default(false) @map("feature_flags_enabled")
  roleFlagMatrixEnabled Boolean  @default(false) @map("role_flag_matrix_enabled")
  active                Boolean  @default(true)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  org           Organisation              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  killSwitches  KillSwitchEntry[]
  flags         FeatureFlagDefinition[]
  roleValues    FeatureFlagRoleValue[]
  userOverrides FeatureFlagUserOverride[]

  @@unique([orgId, identifier])
  @@index([identifier])
  @@index([orgId])
  @@map("apps")
}

model KillSwitchEntry {
  id                 String    @id @default(cuid())
  appId              String    @map("app_id")
  platform           String    @db.VarChar(20)
  type               String    @db.VarChar(20)
  versionField       String    @map("version_field") @db.VarChar(20)
  operator           String    @default("eq") @db.VarChar(10)
  versionValue       String    @map("version_value") @db.VarChar(80)
  versionMax         String?   @map("version_max") @db.VarChar(80)
  versionScheme      String    @map("version_scheme") @db.VarChar(20)
  name               String?   @db.VarChar(120)
  storeUrl           String?   @map("store_url")
  titleKey           String?   @map("title_key") @db.VarChar(160)
  title              String?
  messageKey         String?   @map("message_key") @db.VarChar(160)
  message            String?
  primaryButtonKey   String?   @map("primary_button_key") @db.VarChar(160)
  primaryButton      String?   @map("primary_button")
  secondaryButtonKey String?   @map("secondary_button_key") @db.VarChar(160)
  secondaryButton    String?   @map("secondary_button")
  latestVersion      String?   @map("latest_version") @db.VarChar(80)
  active             Boolean   @default(true)
  activateAt         DateTime? @map("activate_at")
  deactivateAt       DateTime? @map("deactivate_at")
  priority           Int       @default(0)
  testUserIds        Json      @default("[]") @map("test_user_ids")
  cacheTtl           Int       @default(3600) @map("cache_ttl")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@index([appId, active, priority])
  @@index([activateAt])
  @@map("kill_switch_entries")
}

model FeatureFlagDefinition {
  id           String   @id @default(cuid())
  appId        String   @map("app_id")
  key          String   @db.VarChar(80)
  description  String?  @db.VarChar(500)
  defaultState Boolean  @default(false) @map("default_state")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  app           App                       @relation(fields: [appId], references: [id], onDelete: Cascade)
  roleValues    FeatureFlagRoleValue[]
  userOverrides FeatureFlagUserOverride[]

  @@unique([appId, key])
  @@index([appId])
  @@map("feature_flag_definitions")
}

model FeatureFlagRoleValue {
  id        String   @id @default(cuid())
  appId     String   @map("app_id")
  flagKey   String   @map("flag_key") @db.VarChar(80)
  roleName  String   @map("role_name") @db.VarChar(100)
  value     Boolean
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  app  App                   @relation(fields: [appId], references: [id], onDelete: Cascade)
  flag FeatureFlagDefinition @relation(fields: [appId, flagKey], references: [appId, key], onDelete: Cascade)

  @@unique([appId, roleName, flagKey])
  @@index([appId, flagKey])
  @@map("feature_flag_role_values")
}

model FeatureFlagUserOverride {
  id        String   @id @default(cuid())
  appId     String   @map("app_id")
  flagKey   String   @map("flag_key") @db.VarChar(80)
  userId    String   @map("user_id")
  value     Boolean
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  app  App                   @relation(fields: [appId], references: [id], onDelete: Cascade)
  flag FeatureFlagDefinition @relation(fields: [appId, flagKey], references: [appId, key], onDelete: Cascade)
  user User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appId, userId, flagKey])
  @@index([userId])
  @@index([appId, flagKey])
  @@map("feature_flag_user_overrides")
}

model Team {
  id                  String   @id @default(cuid())
  orgId               String   @map("org_id")
  groupId             String?  @map("group_id")
  name                String   @db.VarChar(100)
  slug                String   @db.VarChar(120)
  description         String?  @db.VarChar(500)
  isDefault           Boolean  @default(false) @map("is_default")
  allowedEmailDomains String[] @default([]) @map("allowed_email_domains")
  allowedEmails       String[] @default([]) @map("allowed_emails")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  iconUrl    String?        @map("icon_url") // external URL only, no local storage (brief §15); §11.3
  joinPolicy TeamJoinPolicy @default(INVITE_ONLY) @map("join_policy") // design §4.6

  org            Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  group          Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  members        TeamMember[]
  invites        TeamInvite[]
  inviteLinks    TeamInviteLink[]
  accessRequests AccessRequest[]
  bans           Ban[]

  @@unique([orgId, name])
  @@unique([orgId, slug])
  @@index([orgId])
  @@index([groupId])
  @@map("teams")
}

/// Admin-managed deny list. Scope is derived from which id is set: neither orgId nor
/// teamId set is a client-domain ban; orgId set is an organisation ban; teamId set is a
/// team ban. A ban always overrides any allow-list. Accessed only via the BYPASSRLS admin
/// client (login enforcement has no tenant context yet), like client_domains.
model Ban {
  id             String   @id @default(cuid())
  domain         String
  orgId          String?  @map("org_id")
  teamId         String?  @map("team_id")
  type           BanType
  value          String   @db.VarChar(320)
  reason         String?  @db.VarChar(500)
  createdByEmail String?  @map("created_by_email")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org  Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@index([orgId])
  @@index([teamId])
  @@map("bans")
}

model TeamMember {
  id              String           @id @default(cuid())
  teamId          String           @map("team_id")
  userId          String           @map("user_id")
  teamRole        String           @default("member") @map("team_role") // "owner" | "admin" | "member"
  status          MembershipStatus @default(ACTIVE) // lifecycle (design §4.1)
  statusChangedAt DateTime?        @map("status_changed_at")
  isGuest         Boolean          @default(false) @map("is_guest") // design §4.8 — dormant until guests ship
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId, status])
  @@map("team_members")
}

model TeamInvite {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  teamId          String    @map("team_id")
  email           String
  inviteName      String?   @map("invite_name") @db.VarChar(120)
  teamRole        String    @default("member") @map("team_role")
  redirectUrl     String?   @map("redirect_url")
  invitedByUserId String?   @map("invited_by_user_id")
  invitedByName   String?   @map("invited_by_name") @db.VarChar(120)
  invitedByEmail  String?   @map("invited_by_email")
  acceptedUserId  String?   @map("accepted_user_id")
  acceptedAt      DateTime? @map("accepted_at")
  declinedAt      DateTime? @map("declined_at")
  revokedAt       DateTime? @map("revoked_at")
  openedAt        DateTime? @map("opened_at")
  openCount       Int       @default(0) @map("open_count")
  lastSentAt      DateTime  @map("last_sent_at")
  // Invite-level expiry (design §4.7, Phase 4), independent of the emailed token's own (much
  // shorter) TTL. Nullable so the column is additive; the migration backfills existing unresolved
  // invites to `lastSentAt + 30 days` and every new/resent invite sets `now + 30 days`.
  expiresAt       DateTime? @map("expires_at")
  // Member-initiated invite approval workflow (design §4.7, Phase 4). NOT_REQUIRED for every invite
  // created by an owner/admin (or the backend bulk-invite endpoint) — unchanged behaviour.
  approvalStatus     InviteApprovalStatus @default(NOT_REQUIRED) @map("approval_status")
  requestedByUserId  String?              @map("requested_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  org          Organisation        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  acceptedUser User?               @relation("AcceptedTeamInvites", fields: [acceptedUserId], references: [id], onDelete: SetNull)
  tokens       VerificationToken[]

  @@index([orgId])
  @@index([teamId, email])
  @@index([acceptedAt])
  @@index([revokedAt])
  @@map("team_invites")
}

// Shareable team invite links (design §4.7, Phase 5). Slack-style: a non-personal link that
// authorizes JOINING a team (never authentication) once the redeemer has already verified their
// identity — redemption only happens via `POST /auth/select-team`'s `inviteLinkToken` path, gated
// behind the Phase 3b `login_token` bridge. Only the token HASH is stored (mirrors
// `domain-secret.service.ts`'s claim-token pattern); the plaintext token is returned exactly once,
// at creation.
model TeamInviteLink {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  teamId          String    @map("team_id")
  tokenHash       String    @unique @map("token_hash")
  createdByUserId String?   @map("created_by_user_id")
  roleToAssign    String    @default("member") @map("role_to_assign") // "member" | "admin" — never "owner"
  expiresAt       DateTime  @map("expires_at") // capped at now + 30 days
  maxUses         Int       @default(400) @map("max_uses") // capped at 400
  useCount        Int       @default(0) @map("use_count")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("team_invite_links")
}

model Group {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org     Organisation  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teams   Team[]
  members GroupMember[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("groups")
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model AccessRequest {
  id               String              @id @default(cuid())
  orgId            String              @map("org_id")
  teamId           String              @map("team_id")
  email            String
  requestName      String?             @map("request_name") @db.VarChar(120)
  status           AccessRequestStatus @default(PENDING)
  requestedAt      DateTime            @default(now()) @map("requested_at")
  lastRequestedAt  DateTime            @map("last_requested_at")
  reviewedAt       DateTime?           @map("reviewed_at")
  reviewReason     String?             @map("review_reason") @db.VarChar(500)
  notifiedAt       DateTime?           @map("notified_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  userId           String?             @map("user_id")
  reviewedByUserId String?             @map("reviewed_by_user_id")

  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team       Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?        @relation("ReviewedAccessRequests", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, teamId, status])
  @@index([teamId, email, status])
  @@index([userId])
  @@index([reviewedByUserId])
  @@map("access_requests")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

// Brief 8.4 / Phase 10: AI translation fallback results must be cached permanently after generation.
model AiTranslation {
  language   String   @id
  // Hash of the source translation file used to generate this row (lets us regenerate if the source changes).
  sourceHash String   @map("source_hash")
  data       Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([sourceHash])
  @@map("ai_translations")
}

// HUGO-539: Admin API keys — terminal/CI control of feature flags & kill switches.
// Global/superuser-scoped opaque bearer key. The secret is never persisted, only the
// HMAC-SHA256 digest (peppered with SHARED_SECRET). Admin-only table (deny-all RLS for uoa_app).
model AdminApiKey {
  id              String    @id @default(cuid())
  name            String    @db.VarChar(120)
  keyPrefix       String    @map("key_prefix") @db.VarChar(24)
  secretDigest    String    @unique @map("secret_digest")
  lastUsedAt      DateTime? @map("last_used_at")
  expiresAt       DateTime? @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  createdByUserId String?   @map("created_by_user_id")
  createdByEmail  String?   @map("created_by_email") @db.VarChar(200)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("admin_api_keys")
}
