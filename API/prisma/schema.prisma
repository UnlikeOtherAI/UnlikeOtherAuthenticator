model BillingAppKey {
  id                    String               @id @default(cuid())
  serviceId             String               @map("service_id")
  purpose               BillingAppKeyPurpose @default(ENTITLEMENT)
  name                  String               @db.VarChar(120)
  keyPrefix             String               @map("key_prefix") @db.VarChar(24)
  secretDigest          String               @unique @map("secret_digest")
  actorIssuer           String               @map("actor_issuer") @db.VarChar(2048)
  actorAudience         String               @map("actor_audience") @db.VarChar(2048)
  actorKeyId            String               @map("actor_key_id") @db.VarChar(256)
  actorPublicJwk        Json                 @map("actor_public_jwk")
  checkoutReturnOrigins String[]             @default([]) @map("checkout_return_origins")
  lastUsedAt            DateTime?            @map("last_used_at")
  expiresAt             DateTime?            @map("expires_at")
  revokedAt             DateTime?            @map("revoked_at")
  createdByUserId       String?              @map("created_by_user_id")
  createdByEmail        String?              @map("created_by_email") @db.VarChar(200)
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  service                           BillingService                            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  stripeCheckouts                   BillingStripeCheckoutSession[]
  serviceAccesses                   BillingServiceAccess[]
  cancellationIntents               BillingCancellationIntent[]
  creditAccountAutoTopUps           BillingCreditAccount[]                    @relation("CreditAccountAutoTopUpAppKey")
  creditEntries                     BillingCreditEntry[]
