  successWebhookEventId       String?                             @unique @map("success_webhook_event_id")
  stateWebhookEventId         String?                             @unique @map("state_webhook_event_id")
  status                      BillingCreditAutoTopUpAttemptStatus @default(PENDING)
  failureCode                 String?                             @map("failure_code") @db.VarChar(120)
  creditEntryId               String?                             @unique @map("credit_entry_id")
  resolvedAt                  DateTime?                           @map("resolved_at")
  createdAt                   DateTime                            @default(now()) @map("created_at")
  updatedAt                   DateTime                            @updatedAt @map("updated_at")

  account             BillingStripeAccount                  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  creditAccount       BillingCreditAccount                  @relation(fields: [creditAccountId], references: [id], onDelete: Restrict)
  catalog             BillingCreditTopUpCatalog             @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  service             BillingService                        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appKey              BillingAppKey                         @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  attributedUser      User                                  @relation("CreditAutoTopUpAttribution", fields: [attributedUserId], references: [id], onDelete: Restrict)
  option              BillingCreditAutoTopUpOption          @relation(fields: [optionId], references: [id], onDelete: Restrict)
  offer               BillingCreditTopUpOffer               @relation(fields: [offerId], references: [id], onDelete: Restrict)
  triggerEntry        BillingCreditEntry?                   @relation("CreditAutoTopUpTrigger", fields: [triggerEntryId], references: [id], onDelete: Restrict)
  consentRevision     BillingCreditAutoTopUpConsentRevision @relation(fields: [consentRevisionId], references: [id], onDelete: Restrict)
  creditEntry         BillingCreditEntry?                   @relation("CreditAutoTopUpCredit", fields: [creditEntryId], references: [id], onDelete: Restrict)
  successWebhookEvent BillingStripeWebhookEvent?            @relation("CreditAutoTopUpSuccessEvent", fields: [successWebhookEventId], references: [id], onDelete: Restrict)
  stateWebhookEvent   BillingStripeWebhookEvent?            @relation("CreditAutoTopUpStateEvent", fields: [stateWebhookEventId], references: [id], onDelete: Restrict)

  @@unique([creditAccountId, idempotencyKey])
  @@unique([accountId, stripePaymentIntentId])
  @@index([creditAccountId, status])
  @@index([serviceId, attributedUserId])
  @@index([appKeyId])
  @@index([triggerEntryId])
  @@index([consentRevisionId])
  @@map("billing_credit_auto_top_up_attempts")
}

// UOA alone converts one exact Ledger USD-rated snapshot into credits. Each row
// retains service, product app-key, and user attribution; one mutable invoice line
// later projects the cumulative remainder without creating a line per correction.
model BillingCreditUsageSettlement {
  id                                       String                             @id @default(cuid())
  accountId                                String                             @map("account_id")
  creditAccountId                          String                             @map("credit_account_id")
  subscriptionId                           String?                            @map("subscription_id")
  tariffId                                 String                             @map("tariff_id")
  serviceId                                String                             @map("service_id")
  appKeyId                                 String                             @map("app_key_id")
  billingMonth                             String                             @map("billing_month") @db.Char(7)
  currency                                 String                             @default("USD") @db.Char(3)
  cumulativeRatedUsageAmountMicroMinor     BigInt                             @default(0) @map("cumulative_rated_usage_amount_micro_minor")
  cumulativeCreditsConsumedMicrocredits    BigInt                             @default(0) @map("cumulative_credits_consumed_microcredits")
  cumulativeRemainingUsageAmountMicroMinor BigInt                             @default(0) @map("cumulative_remaining_usage_amount_micro_minor")
  status                                   BillingCreditUsageSettlementStatus @default(PENDING)
  createdAt                                DateTime                           @default(now()) @map("created_at")
  updatedAt                                DateTime                           @updatedAt @map("updated_at")

  account             BillingStripeAccount                      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  creditAccount       BillingCreditAccount                      @relation(fields: [creditAccountId], references: [id], onDelete: Restrict)
  subscription        BillingStripeSubscription?                @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  tariff              BillingTariff                             @relation(fields: [tariffId], references: [id], onDelete: Restrict)
  service             BillingService                            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appKey              BillingAppKey                             @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  adjustments         BillingCreditUsageSettlementAdjustment[]
  allocations         BillingCreditUsageAllocation[]
  invoiceLines        BillingCreditInvoiceLine[]
  contractInvoiceRefs BillingInvoiceCreditSettlementReference[]

  @@unique([creditAccountId, serviceId, billingMonth])
  @@index([accountId])
  @@index([creditAccountId, billingMonth])
  @@index([appKeyId])
  @@map("billing_credit_usage_settlements")
}

// Repeated Ledger snapshots and corrections are append-only. A trigger locks the
// shared account and advances both this cumulative chain and the settlement row.
model BillingCreditUsageSettlementAdjustment {
  id                                       String   @id @default(cuid())
  settlementId                             String   @map("settlement_id")
  accountId                                String   @map("account_id")
  creditAccountId                          String   @map("credit_account_id")
  serviceId                                String   @map("service_id")
  appKeyId                                 String   @map("app_key_id")
  portfolioSnapshotId                      String   @map("portfolio_snapshot_id")
  sequence                                 Int
  deltaRatedUsageAmountMicroMinor          BigInt   @map("delta_rated_usage_amount_micro_minor")
  deltaCreditsConsumedMicrocredits         BigInt   @map("delta_credits_consumed_microcredits")
  deltaRemainingUsageAmountMicroMinor      BigInt   @map("delta_remaining_usage_amount_micro_minor")
  cumulativeRatedUsageAmountMicroMinor     BigInt   @map("cumulative_rated_usage_amount_micro_minor")
  cumulativeCreditsConsumedMicrocredits    BigInt   @map("cumulative_credits_consumed_microcredits")
  cumulativeRemainingUsageAmountMicroMinor BigInt   @map("cumulative_remaining_usage_amount_micro_minor")
  creditEntryId                            String?  @unique @map("credit_entry_id")
  createdAt                                DateTime @default(now()) @map("created_at")

  settlement          BillingCreditUsageSettlement              @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  account             BillingStripeAccount                      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  creditAccount       BillingCreditAccount                      @relation(fields: [creditAccountId], references: [id], onDelete: Restrict)
  service             BillingService                            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appKey              BillingAppKey                             @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  portfolioSnapshot   BillingCreditPortfolioSnapshot            @relation(fields: [portfolioSnapshotId], references: [id], onDelete: Restrict)
  creditEntry         BillingCreditEntry?                       @relation(fields: [creditEntryId], references: [id], onDelete: Restrict)
  allocations         BillingCreditUsageAllocation[]
  currentForLines     BillingCreditInvoiceLine[]                @relation("CreditInvoiceLineCurrentAdjustment")
  contractInvoiceRefs BillingInvoiceCreditSettlementReference[]

  @@unique([settlementId, portfolioSnapshotId])
  @@unique([settlementId, sequence])
  @@index([accountId])
  @@index([creditAccountId, createdAt])
  @@index([serviceId])
  @@index([appKeyId])
  @@map("billing_credit_usage_settlement_adjustments")
}

// Per-user transparency is separate from the aggregate commercial settlement.
// Allocations are append-only and a deferred database constraint verifies that
// their totals equal the parent adjustment before the transaction commits.
model BillingCreditUsageAllocation {
  id                                       String   @id @default(cuid())
  settlementId                             String   @map("settlement_id")
  adjustmentId                             String   @map("adjustment_id")
  serviceId                                String   @map("service_id")
  appKeyId                                 String   @map("app_key_id")
  attributedUserId                         String?  @map("attributed_user_id")
  deltaRatedUsageAmountMicroMinor          BigInt   @map("delta_rated_usage_amount_micro_minor")
  deltaCreditsConsumedMicrocredits         BigInt   @map("delta_credits_consumed_microcredits")
  deltaRemainingUsageAmountMicroMinor      BigInt   @map("delta_remaining_usage_amount_micro_minor")
  cumulativeRatedUsageAmountMicroMinor     BigInt   @map("cumulative_rated_usage_amount_micro_minor")
  cumulativeCreditsConsumedMicrocredits    BigInt   @map("cumulative_credits_consumed_microcredits")
  cumulativeRemainingUsageAmountMicroMinor BigInt   @map("cumulative_remaining_usage_amount_micro_minor")
  createdAt                                DateTime @default(now()) @map("created_at")

  settlement     BillingCreditUsageSettlement           @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  adjustment     BillingCreditUsageSettlementAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Restrict)
  service        BillingService                         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appKey         BillingAppKey                          @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  attributedUser User?                                  @relation("CreditUsageAllocationAttribution", fields: [attributedUserId], references: [id], onDelete: Restrict)

  @@index([adjustmentId, attributedUserId])
  @@index([settlementId, attributedUserId, createdAt])
  @@index([serviceId])
  @@index([appKeyId])
  @@map("billing_credit_usage_allocations")
}

// A settlement has at most one mutable credit-offset line on a given Stripe invoice.
// Snapshot corrections update this cumulative projection instead of adding lines.
model BillingCreditInvoiceLine {
  id                                    String                         @id @default(cuid())
  accountId                             String                         @map("account_id")
  settlementId                          String                         @map("settlement_id")
  subscriptionId                        String                         @map("subscription_id")
  lastAdjustmentId                      String                         @map("last_adjustment_id")
  stripeInvoiceId                       String                         @map("stripe_invoice_id") @db.VarChar(255)
  stripeInvoiceItemId                   String?                        @map("stripe_invoice_item_id") @db.VarChar(255)
  cumulativeCreditsConsumedMicrocredits BigInt                         @map("cumulative_credits_consumed_microcredits")
  stripeUnitAmountDecimal               String                         @default("-0.000001") @map("stripe_unit_amount_decimal") @db.VarChar(20)
  stripeQuantity                        BigInt                         @map("stripe_quantity")
  idempotencyKey                        String                         @map("idempotency_key") @db.VarChar(200)
  status                                BillingCreditInvoiceLineStatus @default(CREATING)
  createdAt                             DateTime                       @default(now()) @map("created_at")
  updatedAt                             DateTime                       @updatedAt @map("updated_at")

  account        BillingStripeAccount                   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  settlement     BillingCreditUsageSettlement           @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  subscription   BillingStripeSubscription              @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  lastAdjustment BillingCreditUsageSettlementAdjustment @relation("CreditInvoiceLineCurrentAdjustment", fields: [lastAdjustmentId], references: [id], onDelete: Restrict)

  @@unique([settlementId, stripeInvoiceId])
  @@unique([accountId, stripeInvoiceItemId])
  @@unique([accountId, idempotencyKey])
  @@index([accountId, stripeInvoiceId])
  @@index([subscriptionId])
  @@index([lastAdjustmentId])
  @@map("billing_credit_invoice_lines")
}

// Recurring add-ons are separate one-item Stripe subscriptions. They never add
// line items to the base tariff subscription and never act as runtime feature authority.
model BillingRecurringAddonOffer {
  id                 String    @id @default(cuid())
  serviceId          String    @map("service_id")
  key                String    @db.VarChar(80)
  version            Int
  name               String    @db.VarChar(120)
  description        String    @db.VarChar(500)
  benefits           String[]  @default([])
  monthlyAmountMinor BigInt    @map("monthly_amount_minor")
  currency           String    @db.Char(3)
  active             Boolean   @default(true)
  deactivatedAt      DateTime? @map("deactivated_at")
  createdByUserId    String?   @map("created_by_user_id")
  createdByEmail     String?   @map("created_by_email") @db.VarChar(200)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  service              BillingService                            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  catalogs             BillingRecurringAddonCatalog[]
  checkouts            BillingRecurringAddonCheckout[]
  subscriptions        BillingRecurringAddonSubscription[]
  featurePolicies      BillingRecurringAddonFeaturePolicy[]
  cancellationIntents  BillingRecurringAddonCancellationIntent[]
  contractInvoiceLines BillingInvoiceAddonLine[]

  @@unique([serviceId, key, version])
  @@index([serviceId, active])
  @@map("billing_recurring_addon_offers")
}

model BillingRecurringAddonFeaturePolicy {
  id               String                                @id @default(cuid())
  serviceId        String                                @map("service_id")
  offerId          String                                @map("offer_id")
  appId            String                                @map("app_id")
  featureFlagKey   String                                @map("feature_flag_key") @db.VarChar(80)
  entitlementScope BillingRecurringAddonEntitlementScope @map("entitlement_scope")
  active           Boolean                               @default(true)
  createdByUserId  String?                               @map("created_by_user_id")
  createdByEmail   String?                               @map("created_by_email") @db.VarChar(200)
  createdAt        DateTime                              @default(now()) @map("created_at")
  updatedAt        DateTime                              @updatedAt @map("updated_at")

  service BillingService             @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  offer   BillingRecurringAddonOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  app     App                        @relation(fields: [appId], references: [id], onDelete: Cascade)
  flag    FeatureFlagDefinition      @relation(fields: [appId, featureFlagKey], references: [appId, key], onDelete: Cascade)

  @@unique([offerId, appId, featureFlagKey, entitlementScope])
  @@index([serviceId, active])
  @@index([appId, featureFlagKey])
  @@map("billing_recurring_addon_feature_policies")
}

model BillingRecurringAddonCatalog {
  id                 String   @id @default(cuid())
  accountId          String   @map("account_id")
  serviceId          String   @map("service_id")
  offerId            String   @map("offer_id")
  currency           String   @db.Char(3)
  monthlyAmountMinor BigInt   @map("monthly_amount_minor")
  stripeLookupKey    String   @map("stripe_lookup_key") @db.VarChar(200)
  stripeProductId    String?  @map("stripe_product_id") @db.VarChar(255)
  stripePriceId      String?  @map("stripe_price_id") @db.VarChar(255)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  account              BillingStripeAccount                @relation(fields: [accountId], references: [id], onDelete: Restrict)
  service              BillingService                      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  offer                BillingRecurringAddonOffer          @relation(fields: [offerId], references: [id], onDelete: Restrict)
  checkouts            BillingRecurringAddonCheckout[]
  subscriptions        BillingRecurringAddonSubscription[]
  contractInvoiceLines BillingInvoiceAddonLine[]

  @@unique([accountId, offerId])
  @@unique([accountId, stripeLookupKey])
  @@unique([accountId, stripeProductId])
  @@unique([accountId, stripePriceId])
  @@index([serviceId])
  @@map("billing_recurring_addon_catalogs")
}

model BillingRecurringAddonCheckout {
  id                       String                                 @id @default(cuid())
  accountId                String                                 @map("account_id")
  appKeyId                 String                                 @map("app_key_id")
  customerId               String                                 @map("customer_id")
  catalogId                String                                 @map("catalog_id")
  serviceId                String                                 @map("service_id")
  offerId                  String                                 @map("offer_id")
  offerKey                 String                                 @map("offer_key") @db.VarChar(80)
  orgId                    String                                 @map("org_id")
  teamId                   String?                                @map("team_id")
  requestedTeamId          String                                 @map("requested_team_id")
  subscribingUserId        String?                                @map("subscribing_user_id")
  scope                    BillingRecurringAddonSubscriptionScope
  scopeKey                 String                                 @map("scope_key") @db.VarChar(520)
  actorJti                 String                                 @map("actor_jti") @db.VarChar(256)
  subjectFingerprint       String                                 @map("subject_fingerprint") @db.Char(64)
  requestedByUserId        String                                 @map("requested_by_user_id")
  successUrlDigest         String                                 @map("success_url_digest") @db.Char(64)
  cancelUrlDigest          String                                 @map("cancel_url_digest") @db.Char(64)
  stripeCheckoutSessionId  String?                                @map("stripe_checkout_session_id") @db.VarChar(255)
  stripeSubscriptionId     String?                                @map("stripe_subscription_id") @db.VarChar(255)
  completionWebhookEventId String?                                @unique @map("completion_webhook_event_id")
  status                   BillingRecurringAddonCheckoutStatus    @default(CREATING)
  leaseExpiresAt           DateTime                               @map("lease_expires_at")
  expiresAt                DateTime?                              @map("expires_at")
  completedAt              DateTime?                              @map("completed_at")
  createdAt                DateTime                               @default(now()) @map("created_at")
  updatedAt                DateTime                               @updatedAt @map("updated_at")

  account                BillingStripeAccount               @relation(fields: [accountId], references: [id], onDelete: Restrict)
  appKey                 BillingAppKey                      @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  customer               BillingStripeCustomer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  catalog                BillingRecurringAddonCatalog       @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  service                BillingService                     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  offer                  BillingRecurringAddonOffer         @relation(fields: [offerId], references: [id], onDelete: Restrict)
  org                    Organisation                       @relation(fields: [orgId], references: [id], onDelete: Restrict)
  team                   Team?                              @relation("RecurringAddonCheckoutScopeTeam", fields: [teamId], references: [id], onDelete: Restrict)
  requestedTeam          Team                               @relation("RecurringAddonCheckoutRequestTeam", fields: [requestedTeamId], references: [id], onDelete: Restrict)
  requestedBy            User                               @relation("RecurringAddonCheckoutRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  subscribingUser        User?                              @relation("RecurringAddonCheckoutSubscriber", fields: [subscribingUserId], references: [id], onDelete: Restrict)
  subscription           BillingRecurringAddonSubscription?
  completionWebhookEvent BillingStripeWebhookEvent?         @relation("RecurringAddonCheckoutCompletionEvent", fields: [completionWebhookEventId], references: [id], onDelete: Restrict)

  @@unique([accountId, stripeCheckoutSessionId])
  @@unique([accountId, stripeSubscriptionId])
  @@index([accountId, serviceId, offerId, scope, scopeKey])
  @@index([appKeyId, actorJti])
  @@index([customerId])
  @@index([orgId])
  @@index([teamId])
  @@index([requestedTeamId])
  @@index([subscribingUserId])
  @@map("billing_recurring_addon_checkouts")
}

model BillingRecurringAddonSubscription {
  id                       String                                 @id @default(cuid())
  accountId                String                                 @map("account_id")
  checkoutId               String                                 @unique @map("checkout_id")
  customerId               String                                 @map("customer_id")
  catalogId                String                                 @map("catalog_id")
  serviceId                String                                 @map("service_id")
  offerId                  String                                 @map("offer_id")
  offerKey                 String                                 @map("offer_key") @db.VarChar(80)
  orgId                    String                                 @map("org_id")
  teamId                   String?                                @map("team_id")
  subscribingUserId        String?                                @map("subscribing_user_id")
  scope                    BillingRecurringAddonSubscriptionScope
  scopeKey                 String                                 @map("scope_key") @db.VarChar(520)
  stripeSubscriptionId     String                                 @map("stripe_subscription_id") @db.VarChar(255)
  stripeItemId             String                                 @map("stripe_item_id") @db.VarChar(255)
  status                   String                                 @db.VarChar(32)
  cancelAtPeriodEnd        Boolean                                @default(false) @map("cancel_at_period_end")
  currentPeriodStart       DateTime?                              @map("current_period_start")
  currentPeriodEnd         DateTime?                              @map("current_period_end")
  initialInvoicePaidAt     DateTime?                              @map("initial_invoice_paid_at")
  initialInvoiceId         String?                                @map("initial_invoice_id") @db.VarChar(255)
  activationWebhookEventId String?                                @unique @map("activation_webhook_event_id")
  entitlementActivatedAt   DateTime?                              @map("entitlement_activated_at")
  entitlementDeactivatedAt DateTime?                              @map("entitlement_deactivated_at")
  livemode                 Boolean
  createdAt                DateTime                               @default(now()) @map("created_at")
  updatedAt                DateTime                               @updatedAt @map("updated_at")

  account                BillingStripeAccount                      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  checkout               BillingRecurringAddonCheckout             @relation(fields: [checkoutId], references: [id], onDelete: Restrict)
  customer               BillingStripeCustomer                     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  catalog                BillingRecurringAddonCatalog              @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  service                BillingService                            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  offer                  BillingRecurringAddonOffer                @relation(fields: [offerId], references: [id], onDelete: Restrict)
  org                    Organisation                              @relation(fields: [orgId], references: [id], onDelete: Restrict)
  team                   Team?                                     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  subscribingUser        User?                                     @relation("RecurringAddonSubscriptionSubscriber", fields: [subscribingUserId], references: [id], onDelete: Restrict)
  activationWebhookEvent BillingStripeWebhookEvent?                @relation("RecurringAddonActivationEvent", fields: [activationWebhookEventId], references: [id], onDelete: Restrict)
  cancellationIntents    BillingRecurringAddonCancellationIntent[]
  contractInvoiceLines   BillingInvoiceAddonLine[]

  @@unique([accountId, stripeSubscriptionId])
  @@unique([accountId, stripeItemId])
  @@unique([accountId, initialInvoiceId])
  @@index([accountId, serviceId, offerId, scope, scopeKey])
  @@index([customerId])
  @@index([orgId])
  @@index([teamId])
  @@index([subscribingUserId])
  @@map("billing_recurring_addon_subscriptions")
}

// A cancellation preview is a single-use, replay-safe capability bound to the
// exact paid add-on, product actor, requester, and entitlement scope. Only a
// digest of the opaque token is persisted.
model BillingRecurringAddonCancellationIntent {
  id                        String                                       @id @default(cuid())
  accountId                 String                                       @map("account_id")
  appKeyId                  String                                       @map("app_key_id")
  subscriptionId            String                                       @map("subscription_id")
  serviceId                 String                                       @map("service_id")
  offerId                   String                                       @map("offer_id")
  orgId                     String                                       @map("org_id")
  teamId                    String?                                      @map("team_id")
  requestedTeamId           String                                       @map("requested_team_id")
  subscribingUserId         String?                                      @map("subscribing_user_id")
  scope                     BillingRecurringAddonSubscriptionScope
  scopeKey                  String                                       @map("scope_key") @db.VarChar(520)
  requestedByUserId         String                                       @map("requested_by_user_id")
  actorJti                  String                                       @map("actor_jti") @db.VarChar(256)
  tokenDigest               String                                       @unique @map("token_digest") @db.Char(64)
  subjectFingerprint        String                                       @map("subject_fingerprint") @db.Char(64)
  idempotencyKey            String                                       @map("idempotency_key") @db.VarChar(200)
  choice                    String                                       @default("cancel_addon") @db.VarChar(32)
  state                     BillingRecurringAddonCancellationIntentState @default(AVAILABLE)
  confirmationRequestDigest String?                                      @map("confirmation_request_digest") @db.Char(64)
  result                    Json?
  expiresAt                 DateTime                                     @map("expires_at")
  consumedAt                DateTime?                                    @map("consumed_at")
  createdAt                 DateTime                                     @default(now()) @map("created_at")
  updatedAt                 DateTime                                     @updatedAt @map("updated_at")

  account         BillingStripeAccount              @relation(fields: [accountId], references: [id], onDelete: Restrict)
  appKey          BillingAppKey                     @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  subscription    BillingRecurringAddonSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  service         BillingService                    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  offer           BillingRecurringAddonOffer        @relation(fields: [offerId], references: [id], onDelete: Restrict)
  org             Organisation                      @relation(fields: [orgId], references: [id], onDelete: Restrict)
  team            Team?                             @relation("RecurringAddonCancellationScopeTeam", fields: [teamId], references: [id], onDelete: Restrict)
  requestedTeam   Team                              @relation("RecurringAddonCancellationRequestTeam", fields: [requestedTeamId], references: [id], onDelete: Restrict)
  subscribingUser User?                             @relation("RecurringAddonCancellationSubscriber", fields: [subscribingUserId], references: [id], onDelete: Restrict)
  requestedBy     User                              @relation("RecurringAddonCancellationRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)

  @@unique([appKeyId, idempotencyKey])
  @@index([subscriptionId, state, expiresAt])
  @@index([orgId, requestedTeamId, requestedByUserId])
  @@index([subscribingUserId])
  @@map("billing_recurring_addon_cancellation_intents")
}
