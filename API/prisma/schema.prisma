  subscriptionId             String    @map("subscription_id")
  ledgerSnapshotCursor       String    @map("ledger_snapshot_cursor") @db.VarChar(80)
  billingMonth               String    @map("billing_month") @db.Char(7)
  billingProduct             String    @map("billing_product") @db.VarChar(100)
  callerProduct              String    @map("caller_product") @db.VarChar(100)
  currency                   String    @db.Char(3)
  cumulativeCustomerCharge   String    @map("cumulative_customer_charge") @db.VarChar(120)
  cumulativeMeterQuantity    BigInt    @map("cumulative_meter_quantity")
  deltaMeterQuantity         BigInt    @map("delta_meter_quantity")
  stripeMeterEventIdentifier String    @unique @map("stripe_meter_event_identifier") @db.VarChar(100)
  stripeMeterEventCreatedAt  DateTime? @map("stripe_meter_event_created_at")
  createdAt                  DateTime  @default(now()) @map("created_at")

  account      BillingStripeAccount      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  subscription BillingStripeSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@unique([subscriptionId, ledgerSnapshotCursor, callerProduct, currency])
  @@index([accountId])
  @@index([subscriptionId, billingMonth, callerProduct, currency, createdAt])
  @@map("billing_stripe_usage_exports")
}

model BillingStripeWebhookEvent {
  id                       String   @id @default(cuid())
  accountId                String   @map("account_id")
  stripeEventId            String   @map("stripe_event_id") @db.VarChar(255)
  type                     String   @db.VarChar(120)
  apiVersion               String?  @map("api_version") @db.VarChar(32)
  livemode                 Boolean
  stripeCreatedAt          DateTime @map("stripe_created_at")
  stripeObjectId           String?  @map("stripe_object_id") @db.VarChar(255)
  stripeObjectStatus       String?  @map("stripe_object_status") @db.VarChar(80)
  stripeCustomerId         String?  @map("stripe_customer_id") @db.VarChar(255)
  stripeCheckoutSessionId  String?  @map("stripe_checkout_session_id") @db.VarChar(255)
  stripePaymentIntentId    String?  @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeChargeId           String?  @map("stripe_charge_id") @db.VarChar(255)
  stripeSetupIntentId      String?  @map("stripe_setup_intent_id") @db.VarChar(255)
  stripePaymentMethodId    String?  @map("stripe_payment_method_id") @db.VarChar(255)
  stripeSubscriptionId     String?  @map("stripe_subscription_id") @db.VarChar(255)
  stripeSubscriptionItemId String?  @map("stripe_subscription_item_id") @db.VarChar(255)
  stripeInvoiceId          String?  @map("stripe_invoice_id") @db.VarChar(255)
  amountMinor              BigInt?  @map("amount_minor")
  currency                 String?  @db.Char(3)
  receivedAt               DateTime @default(now()) @map("received_at")

  account                  BillingStripeAccount                @relation(fields: [accountId], references: [id], onDelete: Restrict)
  creditPaymentAdjustments BillingCreditPaymentAdjustment[]
  creditTopUpCompletions   BillingCreditTopUpCheckout[]        @relation("CreditTopUpCompletionEvent")
  creditSetupCompletions   BillingCreditSetupCheckout[]        @relation("CreditSetupCompletionEvent")
  creditAutoTopUpSuccesses BillingCreditAutoTopUpAttempt[]     @relation("CreditAutoTopUpSuccessEvent")
  creditAutoTopUpStates    BillingCreditAutoTopUpAttempt[]     @relation("CreditAutoTopUpStateEvent")
  addonCheckoutCompletions BillingRecurringAddonCheckout[]     @relation("RecurringAddonCheckoutCompletionEvent")
  addonActivations         BillingRecurringAddonSubscription[] @relation("RecurringAddonActivationEvent")

  @@unique([accountId, stripeEventId])
  @@index([accountId])
  @@index([type, receivedAt])
  @@map("billing_stripe_webhook_events")
}

// Organisation contracts are UOA-owned commercial agreements. Versions and
// their service terms are append-only; an invoice pins one exact version.
model BillingOrganisationContract {
  id              String                            @id @default(cuid())
  orgId           String                            @map("org_id")
  reference       String                            @db.VarChar(100)
  name            String                            @db.VarChar(160)
  status          BillingOrganisationContractStatus @default(DRAFT)
  activatedAt     DateTime?                         @map("activated_at")
  terminatedAt    DateTime?                         @map("terminated_at")
  createdByUserId String?                           @map("created_by_user_id")
  createdByEmail  String?                           @map("created_by_email") @db.VarChar(200)
  createdAt       DateTime                          @default(now()) @map("created_at")
  updatedAt       DateTime                          @updatedAt @map("updated_at")

  org      Organisation                         @relation(fields: [orgId], references: [id], onDelete: Restrict)
  versions BillingOrganisationContractVersion[]
  invoices BillingInvoice[]

  @@unique([orgId, reference])
  @@index([orgId, status])
  @@map("billing_organisation_contracts")
}

model BillingOrganisationContractVersion {
  id                 String   @id @default(cuid())
  contractId         String   @map("contract_id")
  version            Int
  usageMarkupBps     Int      @map("usage_markup_bps")
  currency           String   @db.Char(3)
  paymentTermsDays   Int      @map("payment_terms_days")
  effectiveFromMonth String   @map("effective_from_month") @db.Char(7)
  createdByUserId    String?  @map("created_by_user_id")
  createdByEmail     String?  @map("created_by_email") @db.VarChar(200)
  createdAt          DateTime @default(now()) @map("created_at")

  contract     BillingOrganisationContract  @relation(fields: [contractId], references: [id], onDelete: Restrict)
  serviceTerms BillingContractServiceTerm[]
  invoices     BillingInvoice[]

  @@unique([contractId, version])
  @@unique([contractId, effectiveFromMonth])
  @@index([contractId, effectiveFromMonth])
  @@map("billing_organisation_contract_versions")
}

model BillingContractServiceTerm {
  id                 String   @id @default(cuid())
  contractVersionId  String   @map("contract_version_id")
  serviceId          String   @map("service_id")
  tariffId           String   @map("tariff_id")
  tariffAssignmentId String?  @map("tariff_assignment_id")
  monthlyAmountMinor BigInt   @map("monthly_amount_minor")
  createdAt          DateTime @default(now()) @map("created_at")

  contractVersion  BillingOrganisationContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Restrict)
  service          BillingService                     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  tariff           BillingTariff                      @relation(fields: [tariffId], references: [id], onDelete: Restrict)
  tariffAssignment BillingTariffAssignment?           @relation(fields: [tariffAssignmentId], references: [id], onDelete: SetNull)

  @@unique([contractVersionId, serviceId])
  @@index([serviceId])
  @@index([tariffId])
  @@index([tariffAssignmentId])
  @@map("billing_contract_service_terms")
}

model BillingInvoiceIssuerProfile {
  id                        String    @id @default(cuid())
  key                       String    @unique @db.VarChar(80)
  legalName                 String    @map("legal_name") @db.VarChar(200)
  tradingName               String?   @map("trading_name") @db.VarChar(200)
  billingEmail              String    @map("billing_email") @db.Citext
  address                   Json
  taxIdentifier             String?   @map("tax_identifier") @db.VarChar(100)
  companyRegistrationNumber String?   @map("company_registration_number") @db.VarChar(100)
  invoiceNumberPrefix       String    @unique @map("invoice_number_prefix") @db.VarChar(32)
  active                    Boolean   @default(true)
  deactivatedAt             DateTime? @map("deactivated_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  invoices  BillingInvoice[]
  sequences BillingInvoiceNumberSequence[]

  @@index([active])
  @@map("billing_invoice_issuer_profiles")
}

model BillingOrganisationInvoiceProfile {
  id                     String   @id @default(cuid())
  orgId                  String   @unique @map("org_id")
  legalName              String   @map("legal_name") @db.VarChar(200)
  billingEmail           String   @map("billing_email") @db.Citext
  billingAddress         Json     @map("billing_address")
  taxIdentifier          String?  @map("tax_identifier") @db.VarChar(100)
  purchaseOrderReference String?  @map("purchase_order_reference") @db.VarChar(120)
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  org      Organisation     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  invoices BillingInvoice[]

  @@map("billing_organisation_invoice_profiles")
}

model BillingInvoice {
  id                  String               @id @default(cuid())
  orgId               String               @map("org_id")
  contractId          String               @map("contract_id")
  contractVersionId   String               @map("contract_version_id")
  issuerProfileId     String               @map("issuer_profile_id")
  buyerProfileId      String               @map("buyer_profile_id")
  billingMonth        String               @map("billing_month") @db.Char(7)
  revision            Int                  @default(1)
  status              BillingInvoiceStatus @default(DRAFT)
  invoiceNumber       String?              @unique @map("invoice_number") @db.VarChar(80)
  issueDate           DateTime?            @map("issue_date")
  dueDate             DateTime?            @map("due_date")
  currency            String               @db.Char(3)
  subtotalMinor       BigInt               @map("subtotal_minor")
  taxAmountMinor      BigInt               @default(0) @map("tax_amount_minor")
  totalMinor          BigInt               @map("total_minor")
  creditsAppliedMinor BigInt               @default(0) @map("credits_applied_minor")
  issuerSnapshot      Json                 @map("issuer_snapshot")
  buyerSnapshot       Json                 @map("buyer_snapshot")
  calculationDigest   String               @map("calculation_digest") @db.Char(64)
  pdfObjectKey        String?              @map("pdf_object_key") @db.VarChar(1024)
  pdfSha256           String?              @map("pdf_sha256") @db.Char(64)
  pdfTemplateVersion  String?              @map("pdf_template_version") @db.VarChar(80)
  issuedAt            DateTime?            @map("issued_at")
  voidedAt            DateTime?            @map("voided_at")
  voidReason          String?              @map("void_reason") @db.VarChar(500)
  createdByUserId     String?              @map("created_by_user_id")
  createdByEmail      String?              @map("created_by_email") @db.VarChar(200)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  org                  Organisation                              @relation(fields: [orgId], references: [id], onDelete: Restrict)
  contract             BillingOrganisationContract               @relation(fields: [contractId], references: [id], onDelete: Restrict)
  contractVersion      BillingOrganisationContractVersion        @relation(fields: [contractVersionId], references: [id], onDelete: Restrict)
  issuerProfile        BillingInvoiceIssuerProfile               @relation(fields: [issuerProfileId], references: [id], onDelete: Restrict)
  buyerProfile         BillingOrganisationInvoiceProfile         @relation(fields: [buyerProfileId], references: [id], onDelete: Restrict)
  lines                BillingInvoiceLine[]
  meteringRefs         BillingInvoiceMeteringReference[]
  creditSettlementRefs BillingInvoiceCreditSettlementReference[]
  addonLines           BillingInvoiceAddonLine[]
  paymentEvents        BillingInvoicePaymentEvent[]

  @@unique([contractId, billingMonth, revision])
  @@index([orgId, billingMonth, status])
  @@index([contractVersionId])
  @@index([issuerProfileId])
  @@index([buyerProfileId])
  @@map("billing_invoices")
}

// Customer-facing invoice lines contain only the final calculated price for a
// service. Provider cost, usage units, and token detail never enter this table.
model BillingInvoiceLine {
  id                String   @id @default(cuid())
  invoiceId         String   @map("invoice_id")
  serviceId         String   @map("service_id")
  serviceIdentifier String   @map("service_identifier") @db.VarChar(100)
  serviceName       String   @map("service_name") @db.VarChar(120)
  amountMinor       BigInt   @map("amount_minor")
  currency          String   @db.Char(3)
  position          Int
  createdAt         DateTime @default(now()) @map("created_at")

  invoice BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  service BillingService @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, serviceId])
  @@unique([invoiceId, position])
  @@index([serviceId])
  @@map("billing_invoice_lines")
}

// Ledger evidence is private calculation provenance and is never part of the
// customer invoice view model or generated document.
model BillingInvoiceMeteringReference {
  id                   String   @id @default(cuid())
  invoiceId            String   @map("invoice_id")
  serviceId            String   @map("service_id")
  ledgerSnapshotCursor String   @map("ledger_snapshot_cursor")
  ledgerSnapshotSha256 String   @map("ledger_snapshot_sha256") @db.Char(64)
  capturedAt           DateTime @map("captured_at")
  createdAt            DateTime @default(now()) @map("created_at")

  invoice BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  service BillingService @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, serviceId])
  @@index([serviceId])
  @@map("billing_invoice_metering_references")
}

// Private evidence that an invoice credit came from UOA's canonical exact-team
// settlement chain. Microcredits never enter customer DTOs or PDFs.
model BillingInvoiceCreditSettlementReference {
  id                         String   @id @default(cuid())
  invoiceId                  String   @map("invoice_id")
  serviceId                  String   @map("service_id")
  settlementId               String   @map("settlement_id")
  adjustmentId               String   @map("adjustment_id")
  creditsAppliedMicrocredits BigInt   @map("credits_applied_microcredits")
  createdAt                  DateTime @default(now()) @map("created_at")

  invoice    BillingInvoice                         @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  service    BillingService                         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  settlement BillingCreditUsageSettlement           @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  adjustment BillingCreditUsageSettlementAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, settlementId], map: "billing_invoice_credit_refs_invoice_settlement_key")
  @@unique([invoiceId, adjustmentId], map: "billing_invoice_credit_refs_invoice_adjustment_key")
  @@index([serviceId], map: "billing_invoice_credit_refs_service_idx")
  @@index([settlementId], map: "billing_invoice_credit_refs_settlement_idx")
  @@index([adjustmentId], map: "billing_invoice_credit_refs_adjustment_idx")
  @@map("billing_invoice_credit_settlement_references")
}

// Recurring add-ons remain on their authoritative Stripe subscription. The
// invoice displays their final price as separately billed and excludes them
// from this invoice's subtotal, total, credits, and amount due.
model BillingInvoiceAddonLine {
  id                  String                                 @id @default(cuid())
  invoiceId           String                                 @map("invoice_id")
  serviceId           String                                 @map("service_id")
  serviceIdentifier   String                                 @map("service_identifier") @db.VarChar(100)
  serviceName         String                                 @map("service_name") @db.VarChar(120)
  addonSubscriptionId String                                 @map("addon_subscription_id")
  offerId             String                                 @map("offer_id")
  offerVersion        Int                                    @map("offer_version")
  catalogId           String                                 @map("catalog_id")
  offerKey            String                                 @map("offer_key") @db.VarChar(80)
  offerName           String                                 @map("offer_name") @db.VarChar(120)
  monthlyAmountMinor  BigInt                                 @map("monthly_amount_minor")
  currency            String                                 @db.Char(3)
  scope               BillingRecurringAddonSubscriptionScope
  collection          BillingInvoiceAddonCollection          @default(STRIPE_SEPARATE)
  position            Int
  createdAt           DateTime                               @default(now()) @map("created_at")

  invoice           BillingInvoice                    @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  service           BillingService                    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  offer             BillingRecurringAddonOffer        @relation(fields: [offerId], references: [id], onDelete: Restrict)
  catalog           BillingRecurringAddonCatalog      @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  addonSubscription BillingRecurringAddonSubscription @relation(fields: [addonSubscriptionId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, addonSubscriptionId], map: "billing_invoice_addon_lines_invoice_subscription_key")
  @@unique([invoiceId, position], map: "billing_invoice_addon_lines_invoice_position_key")
  @@index([serviceId], map: "billing_invoice_addon_lines_service_idx")
  @@index([offerId], map: "billing_invoice_addon_lines_offer_idx")
  @@index([catalogId], map: "billing_invoice_addon_lines_catalog_idx")
  @@index([addonSubscriptionId], map: "billing_invoice_addon_lines_subscription_idx")
  @@map("billing_invoice_addon_lines")
}

model BillingInvoiceNumberSequence {
  id              String   @id @default(cuid())
  issuerProfileId String   @map("issuer_profile_id")
  year            Int
  lastValue       BigInt   @default(0) @map("last_value")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  issuerProfile BillingInvoiceIssuerProfile @relation(fields: [issuerProfileId], references: [id], onDelete: Restrict)

  @@unique([issuerProfileId, year])
  @@map("billing_invoice_number_sequences")
}

model BillingInvoicePaymentEvent {
  id              String                           @id @default(cuid())
  invoiceId       String                           @map("invoice_id")
  kind            BillingInvoicePaymentEventKind
  source          BillingInvoicePaymentEventSource
  amountMinor     BigInt                           @map("amount_minor")
  currency        String                           @db.Char(3)
  idempotencyKey  String                           @map("idempotency_key") @db.VarChar(200)
  reference       String?                          @db.VarChar(255)
  occurredAt      DateTime                         @map("occurred_at")
  createdByUserId String?                          @map("created_by_user_id")
  createdByEmail  String?                          @map("created_by_email") @db.VarChar(200)
  createdAt       DateTime                         @default(now()) @map("created_at")

  invoice BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, idempotencyKey])
  @@index([invoiceId, occurredAt])
  @@map("billing_invoice_payment_events")
}

// Credits are a universal UOA unit: 1,000 credits always equals US$1 of UOA-rated
// usage. One account is shared by an exact team across connected services in one
// Stripe account/mode. Microcredits (1 credit = 1,000,000 microcredits) preserve
// exact settlement precision and never appear in the public consumer contract.
model BillingCreditFundingPolicy {
  id                      String    @id @default(cuid())
  serviceId               String    @map("service_id")
  currency                String    @db.Char(3)
  version                 Int
  topUpEnabled            Boolean   @default(false) @map("top_up_enabled")
  automaticTopUpEnabled   Boolean   @default(false) @map("automatic_top_up_enabled")
  automaticConsentVersion String    @map("automatic_consent_version") @db.VarChar(120)
  active                  Boolean   @default(true)
  deactivatedAt           DateTime? @map("deactivated_at")
  createdByUserId         String?   @map("created_by_user_id")
  createdByEmail          String?   @map("created_by_email") @db.VarChar(200)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  service           BillingService                          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  topUpOffers       BillingCreditTopUpOffer[]
  autoTopUpOptions  BillingCreditAutoTopUpOption[]
  autoTopUpAccounts BillingCreditAccount[]
  setupCheckouts    BillingCreditSetupCheckout[]
  consentRevisions  BillingCreditAutoTopUpConsentRevision[]

  @@unique([serviceId, currency, version])
  @@index([serviceId, active])
  @@map("billing_credit_funding_policies")
}

model BillingCreditTopUpOffer {
  id                          String    @id @default(cuid())
  policyId                    String    @map("policy_id")
  serviceId                   String    @map("service_id")
  key                         String    @db.VarChar(80)
  version                     Int
  catalogKey                  String    @map("catalog_key") @db.VarChar(100)
  catalogVersion              Int       @map("catalog_version")
  name                        String    @db.VarChar(120)
  description                 String    @db.VarChar(500)
  paymentAmountMinor          BigInt    @map("payment_amount_minor")
  creditsReceivedMicrocredits BigInt    @map("credits_received_microcredits")
  automaticTopUpEligible      Boolean   @default(true) @map("automatic_top_up_eligible")
  active                      Boolean   @default(true)
  deactivatedAt               DateTime? @map("deactivated_at")
  createdByUserId             String?   @map("created_by_user_id")
  createdByEmail              String?   @map("created_by_email") @db.VarChar(200)
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  policy            BillingCreditFundingPolicy              @relation(fields: [policyId], references: [id], onDelete: Cascade)
  service           BillingService                          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  autoTopUpOptions  BillingCreditAutoTopUpOption[]
  autoTopUpAccounts BillingCreditAccount[]
  topUpCheckouts    BillingCreditTopUpCheckout[]
  setupCheckouts    BillingCreditSetupCheckout[]
  autoTopUpAttempts BillingCreditAutoTopUpAttempt[]
  consentRevisions  BillingCreditAutoTopUpConsentRevision[]

  @@unique([policyId, key, version])
  @@index([serviceId, active])
  @@map("billing_credit_top_up_offers")
}

model BillingCreditAutoTopUpOption {
  id                    String    @id @default(cuid())
  policyId              String    @map("policy_id")
  serviceId             String    @map("service_id")
  refillOfferId         String    @map("refill_offer_id")
  key                   String    @db.VarChar(100)
  version               Int
  thresholdMicrocredits BigInt    @map("threshold_microcredits")
  monthlyChargeCapMinor BigInt    @map("monthly_charge_cap_minor")
  active                Boolean   @default(true)
  deactivatedAt         DateTime? @map("deactivated_at")
  createdByUserId       String?   @map("created_by_user_id")
  createdByEmail        String?   @map("created_by_email") @db.VarChar(200)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  policy            BillingCreditFundingPolicy              @relation(fields: [policyId], references: [id], onDelete: Cascade)
  service           BillingService                          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  refillOffer       BillingCreditTopUpOffer                 @relation(fields: [refillOfferId], references: [id], onDelete: Restrict)
  creditAccounts    BillingCreditAccount[]
  setupCheckouts    BillingCreditSetupCheckout[]
  autoTopUpAttempts BillingCreditAutoTopUpAttempt[]
  consentRevisions  BillingCreditAutoTopUpConsentRevision[]

  @@unique([policyId, key, version])
  @@index([serviceId, active])
  @@index([refillOfferId])
  @@map("billing_credit_auto_top_up_options")
}

// Stripe IDs are account/mode configuration resolved by versioned lookup key.
// Application code uses offer identities and never hard-codes these Stripe IDs.
model BillingCreditTopUpCatalog {
  id                          String   @id @default(cuid())
  accountId                   String   @map("account_id")
  key                         String   @db.VarChar(100)
  version                     Int
  currency                    String   @db.Char(3)
  paymentAmountMinor          BigInt   @map("payment_amount_minor")
  creditsReceivedMicrocredits BigInt   @map("credits_received_microcredits")
  stripeLookupKey             String   @map("stripe_lookup_key") @db.VarChar(200)
  stripeProductId             String?  @map("stripe_product_id") @db.VarChar(255)
  stripePriceId               String?  @map("stripe_price_id") @db.VarChar(255)
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  account           BillingStripeAccount            @relation(fields: [accountId], references: [id], onDelete: Restrict)
  topUpCheckouts    BillingCreditTopUpCheckout[]
  autoTopUpAttempts BillingCreditAutoTopUpAttempt[]

  @@unique([accountId, key, version])
  @@unique([accountId, stripeLookupKey])
  @@unique([accountId, stripePriceId])
  @@index([accountId, stripeProductId])
  @@map("billing_credit_top_up_catalogs")
}

model BillingCreditAccount {
  id                             String                      @id @default(cuid())
  accountId                      String                      @map("account_id")
  customerId                     String                      @map("customer_id")
  orgId                          String                      @map("org_id")
  teamId                         String                      @map("team_id")
  currency                       String                      @default("USD") @db.Char(3)
  balanceMicrocredits            BigInt                      @default(0) @map("balance_microcredits")
  autoTopUpGeneration            Int                         @default(0) @map("auto_top_up_generation")
  autoTopUpState                 BillingCreditAutoTopUpState @default(DISABLED) @map("auto_top_up_state")
  autoTopUpPolicyId              String?                     @map("auto_top_up_policy_id")
  autoTopUpServiceId             String?                     @map("auto_top_up_service_id")
  autoTopUpAppKeyId              String?                     @map("auto_top_up_app_key_id")
