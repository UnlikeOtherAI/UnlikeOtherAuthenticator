model BillingCreditEntry {
  id                       String                      @id @default(cuid())
  creditAccountId          String                      @map("credit_account_id")
  serviceId                String?                     @map("service_id")
  appKeyId                 String?                     @map("app_key_id")
  attributedUserId         String?                     @map("attributed_user_id")
  direction                BillingCreditEntryDirection
  kind                     BillingCreditEntryKind
  amountMicrocredits       BigInt                      @map("amount_microcredits")
  balanceAfterMicrocredits BigInt                      @map("balance_after_microcredits")
  currency                 String                      @default("USD") @db.Char(3)
  idempotencyKey           String                      @map("idempotency_key") @db.VarChar(200)
  sourceType               String                      @map("source_type") @db.VarChar(80)
  sourceId                 String                      @map("source_id") @db.VarChar(255)
  reversesEntryId          String?                     @map("reverses_entry_id")
  occurredAt               DateTime                    @map("occurred_at")
  createdAt                DateTime                    @default(now()) @map("created_at")

  creditAccount                BillingCreditAccount                    @relation(fields: [creditAccountId], references: [id], onDelete: Restrict)
  service                      BillingService?                         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appKey                       BillingAppKey?                          @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  attributedUser               User?                                   @relation("CreditEntryAttribution", fields: [attributedUserId], references: [id], onDelete: Restrict)
  reversesEntry                BillingCreditEntry?                     @relation("CreditEntryReversal", fields: [reversesEntryId], references: [id], onDelete: Restrict)
  reversedBy                   BillingCreditEntry[]                    @relation("CreditEntryReversal")
  topUpCheckout                BillingCreditTopUpCheckout?
  autoTopUpAttempt             BillingCreditAutoTopUpAttempt?          @relation("CreditAutoTopUpCredit")
  triggeredAutoTopUps          BillingCreditAutoTopUpAttempt[]         @relation("CreditAutoTopUpTrigger")
  settlementAdjustment         BillingCreditUsageSettlementAdjustment?
  adminAdjustment              BillingCreditAdminAdjustment?
  paymentAdjustmentDebit       BillingCreditPaymentAdjustment?         @relation("CreditPaymentAdjustmentDebit")
  paymentAdjustmentsOriginated BillingCreditPaymentAdjustment[]        @relation("CreditPaymentAdjustmentOriginal")

  @@unique([creditAccountId, idempotencyKey])
  @@index([creditAccountId, occurredAt])
  @@index([serviceId, attributedUserId, occurredAt])
  @@index([appKeyId])
  @@index([reversesEntryId])
  @@map("billing_credit_entries")
}

// Platform-superuser credit grants and debits retain their own immutable audit
// evidence. Their linked ledger entry deliberately has no product or end-user
// attribution; product-originated entries always retain both service and app key.
model BillingCreditAdminAdjustment {
  id                       String   @id @default(cuid())
  accountId                String   @map("account_id")
  creditAccountId          String   @map("credit_account_id")
  orgId                    String   @map("org_id")
  teamId                   String   @map("team_id")
  signedAmountMicrocredits BigInt   @map("signed_amount_microcredits")
  reason                   String   @db.VarChar(1000)
  idempotencyKey           String   @map("idempotency_key") @db.VarChar(200)
  createdByUserId          String   @map("created_by_user_id")
  createdByEmail           String   @map("created_by_email") @db.VarChar(320)
  createdByAdminDomain     String   @map("created_by_admin_domain") @db.VarChar(255)
  creditEntryId            String   @unique @map("credit_entry_id")
  createdAt                DateTime @default(now()) @map("created_at")

  account       BillingStripeAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  creditAccount BillingCreditAccount @relation(fields: [creditAccountId], references: [id], onDelete: Restrict)
  org           Organisation         @relation(fields: [orgId], references: [id], onDelete: Restrict)
  team          Team                 @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdBy     User                 @relation("CreditAdminAdjustmentCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  creditEntry   BillingCreditEntry   @relation(fields: [creditEntryId], references: [id], onDelete: Restrict)

  @@unique([creditAccountId, idempotencyKey])
  @@index([accountId])
  @@index([orgId, teamId, createdAt])
  @@index([createdByUserId])
  @@map("billing_credit_admin_adjustments")
}

// Verified Stripe refund/dispute evidence is separate from the resulting debit.
// Multiple partial events may reference one paid top-up, but their locked total
// cannot exceed the original credit amount.
model BillingCreditPaymentAdjustment {
  id                    String                             @id @default(cuid())
  accountId             String                             @map("account_id")
  creditAccountId       String                             @map("credit_account_id")
  serviceId             String                             @map("service_id")
  appKeyId              String                             @map("app_key_id")
  kind                  BillingCreditPaymentAdjustmentKind
  originalEntryId       String                             @map("original_entry_id")
  webhookEventId        String                             @map("webhook_event_id")
  stripeObjectId        String                             @map("stripe_object_id") @db.VarChar(255)
  stripePaymentIntentId String                             @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeChargeId        String                             @map("stripe_charge_id") @db.VarChar(255)
  amountMinor           BigInt                             @map("amount_minor")
  amountMicrocredits    BigInt                             @map("amount_microcredits")
  currency              String                             @default("USD") @db.Char(3)
  livemode              Boolean
  idempotencyKey        String                             @map("idempotency_key") @db.VarChar(200)
  creditEntryId         String?                            @unique @map("credit_entry_id")
  occurredAt            DateTime                           @map("occurred_at")
  createdAt             DateTime                           @default(now()) @map("created_at")

  account       BillingStripeAccount      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  creditAccount BillingCreditAccount      @relation(fields: [creditAccountId], references: [id], onDelete: Restrict)
  service       BillingService            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appKey        BillingAppKey             @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  originalEntry BillingCreditEntry        @relation("CreditPaymentAdjustmentOriginal", fields: [originalEntryId], references: [id], onDelete: Restrict)
  webhookEvent  BillingStripeWebhookEvent @relation(fields: [webhookEventId], references: [id], onDelete: Restrict)
  creditEntry   BillingCreditEntry?       @relation("CreditPaymentAdjustmentDebit", fields: [creditEntryId], references: [id], onDelete: Restrict)

  @@unique([accountId, kind, stripeObjectId])
  @@unique([creditAccountId, idempotencyKey])
  @@index([originalEntryId, occurredAt])
  @@index([webhookEventId])
  @@index([accountId, stripePaymentIntentId])
  @@index([serviceId])
  @@index([appKeyId])
  @@map("billing_credit_payment_adjustments")
}

// One immutable, ordered Ledger team portfolio snapshot drives every service
// settlement and user allocation for that team/month. Per-service adjustments
// cannot introduce their own cursors or hashes.
model BillingCreditPortfolioSnapshot {
  id                   String   @id @default(cuid())
  accountId            String   @map("account_id")
  creditAccountId      String   @map("credit_account_id")
  orgId                String   @map("org_id")
  teamId               String   @map("team_id")
  perspectiveServiceId String   @map("perspective_service_id")
  perspectiveProduct   String   @map("perspective_product") @db.VarChar(100)
  billingMonth         String   @map("billing_month") @db.Char(7)
  contract             String   @default("metering-portfolio-v1") @db.VarChar(80)
  groupBy              String   @default("user") @map("group_by") @db.VarChar(32)
  ledgerSnapshotId     String   @map("ledger_snapshot_id") @db.VarChar(80)
  ledgerSnapshotCursor String   @map("ledger_snapshot_cursor") @db.VarChar(80)
  capturedAt           DateTime @map("captured_at")
  sha256               String   @db.Char(64)
  createdAt            DateTime @default(now()) @map("created_at")

  account            BillingStripeAccount                     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  creditAccount      BillingCreditAccount                     @relation(fields: [creditAccountId], references: [id], onDelete: Restrict)
  org                Organisation                             @relation(fields: [orgId], references: [id], onDelete: Restrict)
  team               Team                                     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  perspectiveService BillingService                           @relation("CreditPortfolioPerspectiveService", fields: [perspectiveServiceId], references: [id], onDelete: Restrict)
  adjustments        BillingCreditUsageSettlementAdjustment[]

  @@unique([creditAccountId, ledgerSnapshotId], map: "billing_credit_portfolio_snapshot_ledger_id_key")
  @@unique([creditAccountId, ledgerSnapshotCursor], map: "billing_credit_portfolio_snapshot_cursor_key")
  @@index([accountId])
  @@index([orgId, teamId, billingMonth, capturedAt])
  @@index([perspectiveServiceId])
  @@map("billing_credit_portfolio_snapshots")
}

