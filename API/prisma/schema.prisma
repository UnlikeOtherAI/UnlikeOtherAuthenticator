  creditTopUpCheckouts              BillingCreditTopUpCheckout[]
  creditSetupCheckouts              BillingCreditSetupCheckout[]
  creditAutoTopUpAttempts           BillingCreditAutoTopUpAttempt[]
  creditSettlements                 BillingCreditUsageSettlement[]
  creditSettlementAdjustments       BillingCreditUsageSettlementAdjustment[]
  creditUsageAllocations            BillingCreditUsageAllocation[]
  creditConsentRevisions            BillingCreditAutoTopUpConsentRevision[]
  creditAutoTopUpDisables           BillingCreditAutoTopUpDisableEvent[]
  recurringAddonCheckouts           BillingRecurringAddonCheckout[]
  recurringAddonCancellationIntents BillingRecurringAddonCancellationIntent[]

  @@index([serviceId])
  @@map("billing_app_keys")
}

// UOA-owned evidence that a user has directly authenticated to a product.
// Indirect service use is never promoted to direct access from Ledger metering.
model BillingServiceAccess {
  id               String    @id @default(cuid())
  serviceId        String    @map("service_id")
  appKeyId         String    @map("app_key_id")
  orgId            String    @map("org_id")
  teamId           String    @map("team_id")
  userId           String    @map("user_id")
  active           Boolean   @default(true)
  firstConfirmedAt DateTime  @default(now()) @map("first_confirmed_at")
  lastConfirmedAt  DateTime  @updatedAt @map("last_confirmed_at")
  revokedAt        DateTime? @map("revoked_at")

  service BillingService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  appKey  BillingAppKey  @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  org     Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team    Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serviceId, teamId, userId])
  @@index([orgId, teamId, active])
  @@index([appKeyId])
  @@index([userId])
  @@map("billing_service_accesses")
}

// UOA is the commercial system of record. Fixed add-ons and credits are exact
// integer minor-currency values and are never accepted from Ledger.
model BillingCommercialAdjustment {
  id              String                   @id @default(cuid())
  serviceId       String                   @map("service_id")
  orgId           String                   @map("org_id")
  teamId          String?                  @map("team_id")
  scope           BillingAssignmentScope
  scopeKey        String                   @map("scope_key") @db.VarChar(520)
  key             String                   @db.VarChar(100)
  name            String                   @db.VarChar(160)
  kind            BillingAdjustmentKind
  cadence         BillingAdjustmentCadence
  amountMinor     BigInt                   @map("amount_minor")
  currency        String                   @db.Char(3)
  startsAt        DateTime                 @map("starts_at")
  endsAt          DateTime?                @map("ends_at")
  active          Boolean                  @default(true)
  deactivatedAt   DateTime?                @map("deactivated_at")
  createdByUserId String?                  @map("created_by_user_id")
  createdByEmail  String?                  @map("created_by_email") @db.VarChar(200)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  service BillingService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  org     Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team    Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([serviceId, scope, scopeKey, key, startsAt])
  @@index([orgId, teamId, active, startsAt, endsAt])
  @@map("billing_commercial_adjustments")
}

// Cancellation previews are short-lived, single-use capabilities. Only the
// token digest is persisted; a matching idempotency key may safely resume a
// processing/completed confirmation after an interrupted upstream call.
model BillingCancellationIntent {
  id                      String                         @id @default(cuid())
  tokenDigest             String                         @unique @map("token_digest") @db.Char(64)
  appKeyId                String                         @map("app_key_id")
  serviceId               String                         @map("service_id")
  orgId                   String                         @map("org_id")
  teamId                  String                         @map("team_id")
  requestedByUserId       String                         @map("requested_by_user_id")
  directServiceIds        String[]                       @map("direct_service_ids")
  directSubscriptionIds   String[]                       @map("direct_subscription_ids")
  indirectServiceIds      String[]                       @map("indirect_service_ids")
  entitlementFingerprint  String                         @map("entitlement_fingerprint") @db.Char(64)
  subscriptionFingerprint String                         @map("subscription_fingerprint") @db.Char(64)
  state                   BillingCancellationIntentState @default(AVAILABLE)
  idempotencyKey          String?                        @map("idempotency_key") @db.VarChar(200)
  requestDigest           String?                        @map("request_digest") @db.Char(64)
  result                  Json?
  expiresAt               DateTime                       @map("expires_at")
  consumedAt              DateTime?                      @map("consumed_at")
  createdAt               DateTime                       @default(now()) @map("created_at")
  updatedAt               DateTime                       @updatedAt @map("updated_at")

  appKey      BillingAppKey  @relation(fields: [appKeyId], references: [id], onDelete: Restrict)
  service     BillingService @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  org         Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team        Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requestedBy User           @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)

  @@unique([appKeyId, idempotencyKey])
  @@index([orgId, teamId, expiresAt])
  @@index([requestedByUserId])
  @@map("billing_cancellation_intents")
}

