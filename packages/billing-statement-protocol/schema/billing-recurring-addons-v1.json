          "properties": {
            "stripe_collection_enabled": {
              "type": "boolean"
            },
            "stripe_mode": {
              "enum": [
                "test",
                "live",
                null
              ]
            }
          }
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "offers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "key",
              "version",
              "name",
              "description",
              "benefits",
              "monthly_price",
              "interval",
              "available",
              "unavailable_reason",
              "entitlement",
              "subscription",
              "actions"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "key": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "integer",
                "minimum": 1
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "benefits": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "monthly_price": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "amount",
                  "amount_minor",
                  "currency",
                  "display"
                ],
                "properties": {
                  "amount": {
                    "type": "string",
                    "pattern": "^(?:[1-9][0-9]*(?:\\.[0-9]+)?|0\\.[0-9]*[1-9][0-9]*)$"
                  },
                  "amount_minor": {
                    "type": "string",
                    "pattern": "^[1-9][0-9]*$"
                  },
                  "currency": {
                    "type": "string",
                    "pattern": "^[A-Z]{3}$"
                  },
                  "display": {
                    "type": "string"
                  }
                }
              },
              "interval": {
                "const": "month"
              },
              "available": {
                "type": "boolean"
              },
              "unavailable_reason": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "entitlement": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "state",
                  "display_status",
                  "description"
                ],
                "properties": {
                  "state": {
                    "enum": [
                      "inactive",
                      "pending",
                      "active",
                      "unavailable"
                    ]
                  },
                  "display_status": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              },
              "subscription": {
                "oneOf": [
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "status",
                      "display_status",
                      "scope",
                      "cancel_at_period_end",
                      "current_period_start",
                      "current_period_end",
                      "id",
                      "owner_user_id"
                    ],
                    "properties": {
                      "status": {
                        "type": "string"
                      },
                      "display_status": {
                        "type": "string"
                      },
                      "scope": {
                        "enum": [
                          "organisation",
                          "team",
                          "subscribing_user"
                        ]
                      },
                      "cancel_at_period_end": {
                        "type": "boolean"
                      },
                      "current_period_start": {
                        "anyOf": [
                          {
                            "type": "string",
                            "format": "date-time"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "current_period_end": {
                        "anyOf": [
                          {
                            "type": "string",
                            "format": "date-time"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "owner_user_id": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "minLength": 1
                      }
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "status",
                      "display_status",
                      "scope",
                      "cancel_at_period_end",
                      "current_period_start",
                      "current_period_end",
                      "owner_relationship"
                    ],
                    "properties": {
                      "status": {
                        "type": "string"
                      },
                      "display_status": {
                        "type": "string"
                      },
                      "scope": {
                        "enum": [
                          "organisation",
                          "team",
                          "subscribing_user"
                        ]
                      },
                      "cancel_at_period_end": {
                        "type": "boolean"
                      },
                      "current_period_start": {
                        "anyOf": [
                          {
                            "type": "string",
                            "format": "date-time"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "current_period_end": {
                        "anyOf": [
                          {
                            "type": "string",
                            "format": "date-time"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "owner_relationship": {
                        "enum": [
                          "organisation",
                          "team",
                          "viewer",
                          "other_team_member"
                        ]
                      }
                    }
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "actions": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "id",
                        "kind",
                        "label",
                        "description",
                        "enabled",
                        "disabled_reason",
                        "request"
                      ],
                      "properties": {
                        "id": {
                          "const": "subscribe"
                        },
                        "kind": {
                          "const": "hosted_redirect"
                        },
                        "label": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        },
                        "enabled": {
                          "type": "boolean"
                        },
                        "disabled_reason": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "request": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": [
                            "method",
                            "path",
                            "body"
                          ],
                          "properties": {
                            "method": {
                              "const": "POST"
                            },
                            "path": {
                              "const": "/billing/v1/recurring-addons/checkout"
                            },
                            "body": {
                              "type": "object",
                              "additionalProperties": false,
                              "required": [
                                "product",
                                "organisation_id",
                                "team_id",
                                "user_id",
                                "offer_id"
                              ],
                              "properties": {
                                "product": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 100
                                },
                                "organisation_id": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256
                                },
                                "team_id": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256
                                },
                                "user_id": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256
                                },
                                "offer_id": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "id",
                        "kind",
                        "label",
                        "description",
                        "enabled",
                        "disabled_reason",
                        "request"
                      ],
                      "properties": {
                        "id": {
                          "const": "cancel"
                        },
                        "kind": {
                          "const": "confirmation_dialog"
                        },
                        "label": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        },
                        "enabled": {
                          "type": "boolean"
                        },
                        "disabled_reason": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "request": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": [
                            "method",
                            "path",
                            "body"
                          ],
                          "properties": {
                            "method": {
                              "const": "POST"
                            },
                            "path": {
                              "const": "/billing/v1/recurring-addons/cancellation/preview"
                            },
                            "body": {
                              "type": "object",
                              "additionalProperties": false,
                              "required": [
                                "product",
                                "organisation_id",
                                "team_id",
                                "user_id",
                                "subscription_id"
                              ],
                              "properties": {
                                "product": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 100
                                },
                                "organisation_id": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256
                                },
                                "team_id": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256
                                },
                                "user_id": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256
                                },
                                "subscription_id": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "BillingRecurringAddonCancellationPreviewV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "preview_token",
        "idempotency_key",
        "expires_at",
        "title",
        "description",
        "subscription",
        "confirm_action"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "preview_token": {
          "type": "string",
          "minLength": 32,
          "maxLength": 256
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 16,
          "maxLength": 200
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "subscription": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "offer_name",
            "display_status",
            "cancellation_effective_at"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
