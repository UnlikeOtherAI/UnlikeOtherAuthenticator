              "additionalProperties": false,
              "required": [
                "can_manage_addons"
              ],
              "properties": {
                "can_manage_addons": {
                  "type": "boolean"
                }
              }
            },
            "offers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "subscription",
                  "actions"
                ],
                "properties": {
                  "subscription": {
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                          "status",
                          "display_status",
                          "scope",
                          "cancel_at_period_end",
                          "current_period_start",
                          "current_period_end",
                          "id",
                          "owner_user_id"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          },
                          "display_status": {
                            "type": "string"
                          },
                          "scope": {
                            "enum": [
                              "organisation",
                              "team",
                              "subscribing_user"
                            ]
                          },
                          "cancel_at_period_end": {
                            "type": "boolean"
                          },
                          "current_period_start": {
                            "anyOf": [
                              {
                                "type": "string",
                                "format": "date-time"
                              },
                              {
                                "type": "null"
                              }
                            ]
                          },
                          "current_period_end": {
                            "anyOf": [
                              {
                                "type": "string",
                                "format": "date-time"
                              },
                              {
                                "type": "null"
                              }
                            ]
                          },
                          "id": {
                            "type": "string",
                            "minLength": 1
                          },
                          "owner_user_id": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "minLength": 1
                          }
                        }
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "actions": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "viewer": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "role",
                "entitlement_visibility",
                "description"
              ],
              "properties": {
                "role": {
                  "const": "member"
                },
                "entitlement_visibility": {
                  "const": "own_plus_team_status"
                },
                "description": {
                  "type": "string"
                }
              }
            },
            "capabilities": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "can_manage_addons"
              ],
              "properties": {
                "can_manage_addons": {
                  "const": false
                }
              }
            },
            "offers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "subscription",
                  "actions"
                ],
                "properties": {
                  "subscription": {
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                          "status",
                          "display_status",
                          "scope",
                          "cancel_at_period_end",
                          "current_period_start",
                          "current_period_end",
                          "owner_relationship"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          },
                          "display_status": {
                            "type": "string"
                          },
                          "scope": {
                            "enum": [
                              "organisation",
                              "team",
                              "subscribing_user"
                            ]
                          },
                          "cancel_at_period_end": {
                            "type": "boolean"
                          },
                          "current_period_start": {
                            "anyOf": [
                              {
                                "type": "string",
                                "format": "date-time"
                              },
                              {
                                "type": "null"
                              }
                            ]
                          },
                          "current_period_end": {
                            "anyOf": [
                              {
                                "type": "string",
                                "format": "date-time"
                              },
                              {
                                "type": "null"
                              }
                            ]
                          },
                          "owner_relationship": {
                            "enum": [
                              "organisation",
                              "team",
                              "viewer",
                              "other_team_member"
                            ]
                          }
                        }
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "actions": {
                    "type": "array",
                    "maxItems": 0
                  }
                }
              }
            }
          }
        }
      ],
      "required": [
        "schema_version",
        "generated_at",
        "product",
        "subject",
        "viewer",
        "capabilities",
        "collection",
        "title",
        "description",
        "offers"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "product": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "identifier",
            "name"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "identifier": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "subject": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "user_id",
            "organisation_id",
            "team_id"
          ],
          "properties": {
            "user_id": {
              "type": "string",
              "minLength": 1
            },
            "organisation_id": {
              "type": "string",
              "minLength": 1
            },
            "team_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "viewer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "role",
            "entitlement_visibility",
            "description"
          ],
          "properties": {
            "role": {
              "enum": [
                "member",
                "billing_manager"
