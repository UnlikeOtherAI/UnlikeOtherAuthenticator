            "display_status": {
              "type": "string"
            },
            "cancellation_effective_at": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        "confirm_action": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "path",
            "body"
          ],
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/billing/v1/recurring-addons/cancellation/confirm"
            },
            "body": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "product",
                "organisation_id",
                "team_id",
                "user_id",
                "preview_token",
                "idempotency_key",
                "choice"
              ],
              "properties": {
                "product": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 100
                },
                "organisation_id": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                },
                "team_id": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                },
                "user_id": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                },
                "preview_token": {
                  "type": "string",
                  "minLength": 32,
                  "maxLength": 256
                },
                "idempotency_key": {
                  "type": "string",
                  "minLength": 16,
                  "maxLength": 200
                },
                "choice": {
                  "const": "cancel_addon"
                }
              }
            }
          }
        }
      }
    },
    "BillingRecurringAddonCancellationConfirmRequestV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product",
        "organisation_id",
        "team_id",
        "user_id",
        "preview_token",
        "idempotency_key",
        "choice"
      ],
      "properties": {
        "product": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "organisation_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "team_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "user_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "preview_token": {
          "type": "string",
          "minLength": 32,
          "maxLength": 256
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 16,
          "maxLength": 200
        },
        "choice": {
          "const": "cancel_addon"
        }
      }
    },
    "BillingRecurringAddonCancellationConfirmationV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "status",
        "title",
        "description",
        "cancellation_effective_at"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "status": {
          "enum": [
            "scheduled",
            "already_scheduled"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "cancellation_effective_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
