{
  "name": "@unlikeotherai/billing-statement-protocol",
  "version": "1.2.0",
  "description": "Public UOA billing statement and customer-action consumer contracts",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UnlikeOtherAI/UnlikeOtherAuthenticator.git",
    "directory": "packages/billing-statement-protocol"
  },
  "files": [
    "dist",
    "fixtures",
    "openapi",
    "schema",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema/billing-statement-v1.json": "./schema/billing-statement-v1.json",
    "./schema/billing-statement-v2.json": "./schema/billing-statement-v2.json",
    "./schema/billing-consumer-actions-v1.json": "./schema/billing-consumer-actions-v1.json",
    "./schema/billing-credits-v1.json": "./schema/billing-credits-v1.json",
    "./schema/billing-recurring-addons-v1.json": "./schema/billing-recurring-addons-v1.json",
    "./fixtures/billing-statement-v1.example.json": "./fixtures/billing-statement-v1.example.json",
    "./fixtures/billing-statement-v2.example.json": "./fixtures/billing-statement-v2.example.json",
    "./fixtures/billing-consumer-actions-v1.example.json": "./fixtures/billing-consumer-actions-v1.example.json",
    "./fixtures/billing-credits-v1.example.json": "./fixtures/billing-credits-v1.example.json",
    "./fixtures/billing-recurring-addons-v1.example.json": "./fixtures/billing-recurring-addons-v1.example.json",
    "./openapi/billing-statement-v1.openapi.json": "./openapi/billing-statement-v1.openapi.json",
    "./openapi/billing-statement-v2.openapi.json": "./openapi/billing-statement-v2.openapi.json",
    "./openapi/billing-consumer-actions-v1.openapi.json": "./openapi/billing-consumer-actions-v1.openapi.json",
    "./openapi/billing-credits-v1.openapi.json": "./openapi/billing-credits-v1.openapi.json",
    "./openapi/billing-recurring-addons-v1.openapi.json": "./openapi/billing-recurring-addons-v1.openapi.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/generate-artifacts.mjs --check",
    "generate": "tsc -p tsconfig.build.json && node scripts/generate-artifacts.mjs --write",
    "lint": "node ../../node_modules/eslint/bin/eslint.js \"**/*.{ts,js,mjs}\" --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
